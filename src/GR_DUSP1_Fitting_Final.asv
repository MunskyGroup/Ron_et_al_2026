% Model 11 - Mechanistic TTP Model
%*Pars_GR_DUSP1_TTP_Model_All_2, Dex = 0p3 nM: J_NucCyt=-52.0512; J_TS=-22.5228; J_Total=74.5739
%*Pars_GR_DUSP1_TTP_Model_All_2, Dex = 1 nM: J_NucCyt=-44.4065; J_TS=-30.958; J_Total=75.3644
% Pars_GR_DUSP1_TTP_Model_All_2, Dex = 10 nM: J_NucCyt=-91.2255; J_TS=-47.6437; J_Total=138.8692
%XPars_GR_DUSP1_TTP_Model_All_2, Dex = 100 nM: J_NucCyt=-144.1602; J_TS=-92.7881; J_Total=236.9484
%*Pars_GR_DUSP1_TTP_Model_All_2, Tpl = 0min nM: J_NucCyt=-15.715; J_TS=0; J_Total=15.715
% Pars_GR_DUSP1_TTP_Model_All_2, Tpl = 20min nM: J_NucCyt=-24.4693; J_TS=0; J_Total=24.4693
% Pars_GR_DUSP1_TTP_Model_All_2, Tpl = 75min nM: J_NucCyt=-39.4554; J_TS=0; J_Total=39.4554
%*Pars_GR_DUSP1_TTP_Model_All_2, Tpl = 150min nM: J_NucCyt=-25.6054; J_TS=0; J_Total=25.6054
