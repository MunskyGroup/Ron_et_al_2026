function [Parameters,ParTable] = GR_DUSP1_Fitting_Final(opts)
% Main fitting/prediction/plotting function for the GR-DUSP1 workflow
%
% Preferred usage is now with name-value arguments, for example:
%   GR_DUSP1_Fitting_Final(whichGRmodel=1:4, whichDUSP1modelnuc=1:8,...
%       whichDUSP1modelcyt=[2,3,4,5,6,7,11], makePlots=false);
%
% You can also specify the final model with either its legacy index or a
% readable alias:
%   GR_DUSP1_Fitting_Final(makePlots=true, finalModel='kon')
%   GR_DUSP1_Fitting_Final(makePlots=true, finalModel='full')
%   GR_DUSP1_Fitting_Final(makePlots=true, finalModel='mechanistic')

arguments
    opts.refitGR logical = false
    opts.runMHGR logical = false
    opts.refitDUSP1nuc logical = false
    opts.refitDUSP1cyt logical = false
    opts.refitKTPTL logical = false
    opts.whichGRmodel = []
    opts.whichDUSP1modelnuc = []
    opts.whichDUSP1modelcyt = []
    opts.makePlots logical = false
    opts.finalDUSP1model = []
    opts.makePredictions logical = false
    opts.makeTPLPlots logical = false
    opts.makeTSPlots logical = false
    opts.makeTitrPlots logical = false
    opts.useCluster logical = false
    opts.recomputeSSA logical = false
    opts.computeFano logical = false
    opts.recomputeGR logical = false
    opts.recomputeDUSP1nuc logical = true
    opts.recomputeFullModel logical = true
    opts.hideFigures logical = false
end

refitGR = opts.refitGR;
runMHGR = opts.runMHGR;
refitDUSP1nuc = opts.refitDUSP1nuc;
refitDUSP1cyt = opts.refitDUSP1cyt;
refitKTPTL = opts.refitKTPTL;
GRmodel = opts.whichGRmodel;
DUSP1modelnuc = opts.whichDUSP1modelnuc;
DUSP1modelcyt = opts.whichDUSP1modelcyt;
makePlots = opts.makePlots;
finalDUSP1model = opts.finalDUSP1model;
makePredictions = opts.makePredictions;
useCluster = opts.useCluster;
recomputeSSA = opts.recomputeSSA;
computeFano = opts.computeFano;
makeTitrPlots = opts.makeTitrPlots;
makeTPLPlots = opts.makeTPLPlots;
makeTSPlots = opts.makeTSPlots;
recomputeGR = opts.recomputeGR;
recomputeDUSP1nuc = opts.recomputeDUSP1nuc;
recomputeFullModel = opts.recomputeFullModel;
hideFigures = opts.hideFigures;

if hideFigures
    set(0,'defaultFigureVisible','off')
    figVis = 'off';
else
    figVis = 'on';
    set(0,'defaultFigureVisible','on')
end


%setenv('QT_QPA_PLATFORM','offscreen');
%setenv('TMPDIR', getenv('TMPDIR'));
%parpool('local');

%% Preliminary Definitions
% This script fits/predicts all data from Eric Ron's experimental
% measurement of GR translocation and DUSP1 activation/maturation versus
% time after different levels of dexamethasone.

%close all
% addpath(genpath('../../SSIT'));
if useCluster
    rng('shuffle');
    curDir = pwd;
    cd '../../SSIT';
    install(0,0,0,1,0,1);
    cd(curDir);
end

addpath(genpath('tmpPropensityFunctions'));
% addpath('GR_DUSP1_Plotting_Functions')

% addpath('tmpPropensityFunctions/')
modelLibrary = 'savedParameters/GRDusp1ModelLibrary';
savedParsFile ='savedParameters/Parameters_Final';

fitOptions = optimset('Display','iter','MaxIter',500);
fitIters = 10;

dataFileGR = 'Data/GR_SSITcellresults_Final_Sep18.csv';
dataFileDusp1 = 'Data/DUSP1_SSITcellresults_Final_Sep18.csv';

metricsFile = 'savedResults/Metrics.mat';

%% STEP 0-INIT -- Regenerate model library if needed.
% This should only need to be run once on any new machine.
if ~exist([modelLibrary,'.mat'],'file')
    combined_GRModel = dusp1ModelLibrary_Final('combinedGRModel',true,modelLibrary,dataFileGR,dataFileDusp1);
end

% Check that it loaded properly and otherwise regenerate all models and
% propensity functions.
try
    combined_GRModel = dusp1ModelLibrary_Final('combinedGRModel', false, modelLibrary);
    assert(~isempty(combined_GRModel), 'combined_GRModel is empty.');
    assert(iscell(combined_GRModel.SSITModels), 'SSITModels missing or invalid.');
    assert(numel(combined_GRModel.SSITModels) == 3, 'Expected 3 GR submodels.');
    assert(~isempty(combined_GRModel.parameterIndices), 'parameterIndices missing.');
    assert(~isempty(combined_GRModel.parameters), 'parameters missing.');
    for k = 1:numel(combined_GRModel.SSITModels)
        M = combined_GRModel.SSITModels{k};
        assert(~isempty(M.propensityFunctions), 'Missing propensityFunctions in submodel %d.', k);
        assert(~isempty(M.stoichiometry), 'Missing stoichiometry in submodel %d.', k);
        assert(~isempty(M.parameters), 'Missing parameters in submodel %d.', k);
        assert(~isempty(M.dataSet), 'Missing dataSet in submodel %d.', k);
    end
catch
    disp('Model load failed -- rebuilding models. Please wait.')
    combined_GRModel = dusp1ModelLibrary_Final('combinedGRModel', true, modelLibrary, dataFileGR, dataFileDusp1);
end

%% STEP 1-GRAM -- Fit and choose optimal GR Alternate Model.
GRModelNames = {'combinedGRModel','combinedGRModel_CytDegOnly',...
    'combinedGRModel_NucDegOnly','combinedGRModel_DexExport'};
savedGRParSet = {'GRpars','Pars_CytDegOnly','Pars_NucDegOnly','Pars_DexExport'};
numGRpars = nan(size(GRModelNames));
GRLogPost = nan(size(GRModelNames));
LaplaceEvidence = nan(size(GRModelNames));

for iModel = GRmodel
    [combined_GRModel,log10PriorMean,log10PriorStd] = dusp1ModelLibrary_Final(GRModelNames{iModel},false,modelLibrary, ...
        dataFileGR,dataFileDusp1);

    load(savedParsFile,savedGRParSet{iModel})
    eval(['GRparsAlt=',savedGRParSet{iModel},';']);

    saveVarName = ['logLikelihood_', GRModelNames{iModel}];
    if recomputeGR
        combined_GRModel = combined_GRModel.updateModels(GRparsAlt, false);
        logLikelihood = combined_GRModel.computeTotalLogLikelihood(GRparsAlt);
        
        % Compute FIM, H and Laplace approx of evidence
        combined_GRModel = combined_GRModel.computeFIMs;
        Happrox = combined_GRModel.FIM.totalFIM + diag(1./log10PriorStd(combined_GRModel.SSITModels{1}.fittingOptions.modelVarsToFit));
        k = length(combined_GRModel.SSITModels{1}.fittingOptions.modelVarsToFit);
        S.(['laplaceEvidence_', GRModelNames{iModel}]) = logLikelihood + 0.5*k*log(2*pi) - 0.5*log(det(Happrox));
        S.(['logLikelihood_', GRModelNames{iModel}]) = logLikelihood;
        save(metricsFile,'-struct','S','-append')
    end

    %   Fit GR MultiModel
    if refitGR
        for jj = 1:fitIters
            combined_GRModel = combined_GRModel.updateModels(GRparsAlt, false);
            GRparsAlt = combined_GRModel.maximizeLikelihood(GRparsAlt, fitOptions);
            eval([savedGRParSet{iModel},'=GRparsAlt;']);
            save(savedParsFile,savedGRParSet{iModel},'-append')
        end
        combined_GRModel = combined_GRModel.updateModels(GRparsAlt, false);
        logLikelihood = combined_GRModel.computeTotalLogLikelihood(GRparsAlt);
        S.(saveVarName) = logLikelihood;
        save(metricsFile,'-struct','S','-append')
        GRLogPost(iModel) = logLikelihood;
        disp(['Log-Posterior for model ', GRModelNames{iModel}, ' = ', num2str(logLikelihood)])
        
        combined_GRModel = combined_GRModel.computeFIMs;
        Happrox = combined_GRModel.FIM.totalFIM + diag(1./log10PriorStd(combined_GRModel.SSITModels{1}.fittingOptions.modelVarsToFit));
        k = length(combined_GRModel.SSITModels{1}.fittingOptions.modelVarsToFit);
        LaplaceEvidence(iModel) = logLikelihood + 0.5*k*log(2*pi) - 0.5*log(det(Happrox));
        S.(['laplaceEvidence_', GRModelNames{iModel}]) = LaplaceEvidence(iModel);
        save(metricsFile,'-struct','S','-append')

    else
        S = load(metricsFile, ['logLikelihood_', GRModelNames{iModel}],['laplaceEvidence_', GRModelNames{iModel}]);
        logLikelihood = S.(['logLikelihood_', GRModelNames{iModel}]);
        LaplaceEvidence(iModel)  = S.(['laplaceEvidence_', GRModelNames{iModel}]);
        GRLogPost(iModel) = logLikelihood;
        disp(['Log-Posterior for model ', GRModelNames{iModel}, ' = ', num2str(logLikelihood)])
        disp(['Laplace-Evidence for model ', GRModelNames{iModel}, ' = ', num2str(LaplaceEvidence(iModel))])
    end

    if runMHGR
        disp('Starting MH for GR Model')

        % calculate FIM
        combined_GRModel = combined_GRModel.computeFIMs([],'log');
        FIMGRraw = combined_GRModel.FIM.totalFIM;
        % add prior to FIM
        FIMGR = FIMGRraw +...
            diag(1./log10PriorStd(combined_GRModel.SSITModels{1}.fittingOptions.modelVarsToFit))/log(10)^2;
        FIMGR = (FIMGR+FIMGR')/2;
        covGR = 0.3*FIMGR^-1;
        
        % Set MH Fitting options
        fitOptions.proposalDistribution=@(x)mvnrnd(x,covGR);
        fitOptions.numberOfSamples=10000;
        fitOptions.progress=false;
        fitOptions.useFIMforMetHast = false;
        fitOptions.logForm = true;
        
        [~,~,mhResultsGR] = combined_GRModel.maximizeLikelihood([],fitOptions,'MetropolisHastings');

        save('savedParameters/MHResults_GR_Model.mat','mhResultsGR');
    end

    % Finalize and display the results
    disp('Model fitting and comparison completed successfully.');

    modelFile = ['savedModels/',GRModelNames{iModel}];
    saveDcName = [GRModelNames{iModel}];
    solnToSave = [];
    solnToSave.(saveDcName) = combined_GRModel;
    save(modelFile,'-struct','solnToSave')

    % Number of free parameters in each GR model:
    numGRpars(iModel) = size(combined_GRModel.SSITModels{1}.fittingOptions.modelVarsToFit,2);

    % Compare GR Models (posterior ratios, AIC, BIC)
    nGR = sum(cellfun(@(m) sum(m.dataSet.nCells), combined_GRModel.SSITModels));

    % Information criteria:
    GRAIC = 2*numGRpars - 2*GRLogPost;
    GRBIC = numGRpars*log(nGR) - 2*GRLogPost;

    % Differences relative to the best model:
    [bestLogPost, iBestLogPost] = max(GRLogPost);
    [bestAIC, iBestAIC] = min(GRAIC);
    [bestBIC, iBestBIC] = min(GRBIC);

    DeltaLogPost = GRLogPost - bestLogPost;
    PosteriorRatioVsBest = exp(DeltaLogPost);

    DeltaAIC = GRAIC - bestAIC;
    DeltaBIC = GRBIC - bestBIC;

    % BIC approximate Bayes factor against the best BIC model.
    % BF_i_vs_best < 1 means model i is worse than the best model.
    ApproxBFvsBest_BIC = exp(-0.5*DeltaBIC);

    %% Compute FIM, H and Laplace approx of evidence
    % combined_GRModel = combined_GRModel.computeFIMs;
    % Happrox = combined_GRModel.FIM.totalFIM + diag(1./log10PriorStd(combined_GRModel.SSITModels{1}.fittingOptions.modelVarsToFit));
    % k = length(combined_GRModel.SSITModels{1}.fittingOptions.modelVarsToFit);
    % LaplaceEvidence(iModel) = GRLogPost(iModel) + 0.5*k*log(2*pi) - 0.5*log(det(Happrox));

    %%
    if makePlots
        combined_GRModel = dusp1ModelLibrary_Final(GRModelNames{iModel}, false, modelLibrary, ...
            dataFileGR, dataFileDusp1);
    
        load(savedParsFile, savedGRParSet{iModel})
        GRparsAlt = eval(savedGRParSet{iModel});
    
        figHandlesGR = makeGRPlots(combined_GRModel, GRparsAlt, splitReps=false, GR_Data=dataFileGR);
    
        outDir = 'savedFigures/RawFigs/';
        if ~exist(outDir, 'dir')
            mkdir(outDir);
        end
    
        for i = 1:3
            dex = num2str(combined_GRModel.SSITModels{i}.parameters{13,2});
    
            for j = 1:4
                % Make sure the requested entry exists
                if i > numel(figHandlesGR) || j > numel(figHandlesGR{i})
                    warning('figHandlesGR{%d}{%d} does not exist. Skipping.', i, j);
                    continue
                end
    
                h = figHandlesGR{i}{j};
    
                % Skip empties
                if isempty(h)
                    warning('figHandlesGR{%d}{%d} is empty. Skipping.', i, j);
                    continue
                end
    
                % If this is not a valid graphics handle, skip it
                if ~isgraphics(h)
                    warning('figHandlesGR{%d}{%d} is not a valid graphics handle. Skipping.', i, j);
                    continue
                end
    
                % savefig/saveas with .fig needs a figure handle
                if ~isa(h, 'matlab.ui.Figure')
                    hFig = ancestor(h, 'figure');
                else
                    hFig = h;
                end
    
                if isempty(hFig) || ~isgraphics(hFig, 'figure')
                    warning('Could not resolve a valid figure for figHandlesGR{%d}{%d}. Skipping.', i, j);
                    continue
                end
    
                saveas(hFig, fullfile(outDir, [GRModelNames{iModel}, '_Dex', dex, '_', num2str(j), '.fig']), 'fig');
            end
        end
        close all
    end
end

if GRmodel>0
    GRModelComparison = table( ...
        GRModelNames(:), ...
        numGRpars(:), ...
        repmat(nGR, numel(GRModelNames), 1), ...
        GRLogPost(:), ...
        DeltaLogPost(:), ...
        PosteriorRatioVsBest(:), ...
        GRAIC(:), ...
        DeltaAIC(:), ...
        GRBIC(:), ...
        DeltaBIC(:), ...
        ApproxBFvsBest_BIC(:), ...
        LaplaceEvidence(:), ...
        'VariableNames', {'Model','nPars','nCells','LogPosterior','DeltaLogPosterior', ...
        'PosteriorRatioVsBest','AIC','DeltaAIC','BIC','DeltaBIC','Approx BF vs Best BIC',...
        'LaplaceEvidence'} ...
        );

    disp(GRModelComparison)

    save(metricsFile, 'GRModelComparison', '-append')

    disp(['Best GR model by log-posterior: ', GRModelNames{iBestLogPost}])
    disp(['Best GR model by AIC: ', GRModelNames{iBestAIC}])
    disp(['Best GR model by BIC: ', GRModelNames{iBestBIC}])
end

%% STEP 2-DANM -- DUSP1 Alternate Nuclear Models
savedNucParSet = {'Pars_KOFF','Pars_KON','Pars_KR','Pars_KON_KOFF_KR',...
    'Pars_KON_KOFF','Pars_KON_KOFF_KR_zeroOFF','Pars_KON_KOFF_zeroOFF','Pars_KON_zeroOFF'};

DUSP1nucModelNames = {'KOFF','KON','KR','KON_KOFF_KR','KON_KOFF','KON_KOFF_KR_zeroOFF','KON_KOFF_zeroOFF','KON_zeroOFF'};
numDUSP1nucpars = nan(size(DUSP1nucModelNames));
DUSP1nucLogPost = nan(size(DUSP1nucModelNames));
DUSP1NucLogPosterior = nan(size(DUSP1nucModelNames));
DUSP1NucTSLogLik     = nan(size(DUSP1nucModelNames));
DUSP1NucTotalScore   = nan(size(DUSP1nucModelNames));
DUSP1NucBIC          = nan(size(DUSP1nucModelNames));

% Load DUSP1 Nuclear Model
[DUSP1_Model_100nM,log10PriorMean,log10PriorStd] = ...
    dusp1ModelLibrary_Final('ModelDUSP1_100nM',false,modelLibrary);

% Load and update GR Parameters from previous section.
load(savedParsFile,'GRpars');
DUSP1_Model_100nM.parameters(5:12,2) = num2cell(GRpars);

% Load data for Transcription Sites.
allData = readtable(dataFileDusp1);
allData = allData(allData.cyto_area_px>=12593&allData.cyto_area_px<=17685&isnan(allData.time_tpl),:);

% Number of cells
nDUSP1Nuc = sum(DUSP1_Model_100nM.dataSet.nCells);

tableCount = 0;

figHandlesDUSP1NucTS = cell(size(DUSP1nucModelNames));

for iModel = DUSP1modelnuc
    % Load Model Dependent Parameters
    load(savedParsFile,savedNucParSet{iModel})
    eval(['DUSP1parsAlt=',savedNucParSet{iModel},';']);

    switch iModel
        case 1 % KOFF
            DUSP1_Model_100nM.fittingOptions.modelVarsToFit = [1,2,3,4,19,23,25];
            zeroPars = [24,26];
        case 2 % KON
            DUSP1_Model_100nM.fittingOptions.modelVarsToFit = [1,2,3,4,19,23,24];
            zeroPars = [25,26];
        case 3 % KR
            DUSP1_Model_100nM.fittingOptions.modelVarsToFit = [1,2,3,4,19,23,26];
            zeroPars = [24,25];
        case 4 % General 2-State (KON, KOFF, KR)
            DUSP1_Model_100nM.fittingOptions.modelVarsToFit = [1,2,3,4,19,23,24,25,26];
            zeroPars = [];
        case 5 % General 2-State (KON, KOFF)
            DUSP1_Model_100nM.fittingOptions.modelVarsToFit = [1,2,3,4,19,23,24,25];
            zeroPars = [26];
        case 6 % General 2-State (KON, KOFF, KR) -- no production in OFF state
            DUSP1_Model_100nM.fittingOptions.modelVarsToFit = [1,2,3,4,19,24,25,26];
            zeroPars = [23];
        case 7 % General 2-State (KON, KOFF) -- no production in OFF state
            DUSP1_Model_100nM.fittingOptions.modelVarsToFit = [1,2,3,4,19,24,25];
            zeroPars = [23,26];
        case 8 % General 2-State (KON) -- no production in OFF state
            DUSP1_Model_100nM.fittingOptions.modelVarsToFit = [1,2,3,4,19,24];
            zeroPars = [23,25,26];
    end

    % Number of free parameters in each GR model:
    numDUSP1nucpars(iModel) = size(DUSP1_Model_100nM.fittingOptions.modelVarsToFit,2);

    % Update prior to reflect free parameters
    DUSP1_Model_100nM.fittingOptions.logPrior = ...
        @(x)-sum((log10(reshape(x,[numel(x),1]))-...
        log10PriorMean(DUSP1_Model_100nM.fittingOptions.modelVarsToFit)).^2./...
        (2*log10PriorStd(DUSP1_Model_100nM.fittingOptions.modelVarsToFit).^2));

    % Update parameters from previous saved file.
    DUSP1_Model_100nM.parameters(DUSP1_Model_100nM.fittingOptions.modelVarsToFit,2) = num2cell(DUSP1parsAlt);

    % Set removed parameters to zero.
    DUSP1_Model_100nM.parameters(zeroPars,2) = num2cell(zeros(length(zeroPars),1));

    % Fit metrics names
    saveNames.logP = ['logPosterior_', savedNucParSet{iModel}];
    saveNames.ts   = ['logLikelihood_TS_', savedNucParSet{iModel}];
    saveNames.tot  = ['TotalError_', savedNucParSet{iModel}];
    saveNames.bic  = ['BIC_', savedNucParSet{iModel}];

    if recomputeDUSP1nuc
        modelFile = ['savedModels/',DUSP1nucModelNames{iModel}];
        saveDcName = [DUSP1nucModelNames{iModel}];
        solnToSave = [];
        solnToSave.(saveDcName) = DUSP1_Model_100nM;
        save(modelFile,'-struct','solnToSave')

        % Update model for TS analysis
        ModelTS = DUSP1_Model_100nM;
        ModelTS.tSpan = unique(allData.time)';
        ModelTS.fittingOptions.logPrior = []; % Remove parameters prior since this is already included in the nuclear model.

        % Define loss functions.
        nucObj = @(x)DUSP1_Model_100nM.computeLikelihood(x);
        tsObj = @(x)computeTSlikelihood(x,ModelTS,allData,50,true);

        % Compute posterior
        FitNucError = nucObj(DUSP1parsAlt);

        % Compute TS Likelihood function.
        TSLikelihood = tsObj(DUSP1parsAlt);

        % Compute total posterior
        FitTotalError = FitNucError + TSLikelihood;

        BIC = -2*FitTotalError + ...
            length(DUSP1_Model_100nM.fittingOptions.modelVarsToFit)*log(sum(DUSP1_Model_100nM.dataSet.nCells));

        metricsToSave.(saveNames.logP) = FitNucError;
        metricsToSave.(saveNames.ts)   = TSLikelihood;
        metricsToSave.(saveNames.tot)  = FitTotalError;
        metricsToSave.(saveNames.bic)  = BIC;

        if exist(metricsFile,'file')
            save(metricsFile,'-struct','metricsToSave','-append')
        else
            save(metricsFile,'-struct','metricsToSave')
        end

        metricBase = ['DUSP1_', savedNucParSet{iModel}, '_'];
        disp(['Log-Posterior for model ', metricBase, ' = ', ...
            num2str(FitNucError), '(NUC), ', ...
            num2str(TSLikelihood), '(TS), ', ...
            num2str(FitTotalError), '(TOTAL), ', ...
            num2str(BIC), '(BIC)'])

        DUSP1NucLogPosterior(iModel) = FitNucError;
        DUSP1NucTSLogLik(iModel)     = TSLikelihood;
        DUSP1NucTotalScore(iModel)   = FitTotalError;
        DUSP1NucBIC(iModel)          = BIC;

        DUSP1_Model_100nM.parameters(DUSP1_Model_100nM.fittingOptions.modelVarsToFit,:)

        modelFile = ['savedModels/',DUSP1nucModelNames{iModel}];
        saveDcName = [DUSP1nucModelNames{iModel}];
        solnToSave = [];
        solnToSave.(saveDcName) = DUSP1_Model_100nM;
        save(modelFile,'-struct','solnToSave')
    end

    if refitDUSP1nuc
        % Solve once to define FSP projection
        [~,~,DUSP1_Model_100nM] = DUSP1_Model_100nM.solve;

        modelFile = ['savedModels/',DUSP1nucModelNames{iModel}];
        saveDcName = [DUSP1nucModelNames{iModel}];
        solnToSave = [];
        solnToSave.(saveDcName) = DUSP1_Model_100nM;
        save(modelFile,'-struct','solnToSave')

        % Update model for TS analysis
        ModelTS = DUSP1_Model_100nM;
        ModelTS.tSpan = unique(allData.time)';
        ModelTS.fittingOptions.logPrior = []; % Remove parameters prior since this is already included in the nuclear model.

        % Define loss functions.
        nucObj = @(x)DUSP1_Model_100nM.computeLikelihood(x);
        tsObj = @(x)computeTSlikelihood(x,ModelTS,allData,50,true);
        totalObj = @(x)-(nucObj(exp(x))+tsObj(exp(x)));

        % Fit model to data
        fitParsOld = 0*DUSP1parsAlt;
        ifit = 0;
        % run fit until it no longer changes or fitIters rounds (which ever is sooner)
        while (max(abs(fitParsOld-DUSP1parsAlt))>1e-4)&&ifit<=fitIters
            fitParsOld = DUSP1parsAlt;
            DUSP1parsAlt = exp(fminsearch(totalObj,log(DUSP1parsAlt),fitOptions));
            eval([savedNucParSet{iModel},'=DUSP1parsAlt;']);
            DUSP1_Model_100nM.parameters(DUSP1_Model_100nM.fittingOptions.modelVarsToFit,2) = num2cell(DUSP1parsAlt);
            [~,~,DUSP1_Model_100nM] = DUSP1_Model_100nM.solve;
            ModelTS.parameters(ModelTS.fittingOptions.modelVarsToFit,2) = num2cell(DUSP1parsAlt);
            save(savedParsFile,savedNucParSet{iModel},'-append')
            ifit = ifit+1;
        end

        % Compute posterior
        FitNucError = nucObj(DUSP1parsAlt);

        % Compute TS Likelihood function.
        [TSLikelihood,modelResults,dataResults] = tsObj(DUSP1parsAlt);

        % Compute total posterior
        FitTotalError = FitNucError + TSLikelihood;

        % Make nuclear mRNA means and TS fractions and means plots:
        if makeTSPlots
            figHandlesDUSP1NucTS{iModel} = makeDUSP1NucTSPlots(ModelTS,...
                                      allData, DUSP1nucModelNames{iModel});
            figHandlesDusp1TS{iModel} = makeTSPlotsFSP(modelResults,dataResults,ModelTS,4,'pdf');

            saveNames.TSLikelihood = ['TSLikelihood_', savedNucParSet{iModel}];
            saveNames.modelResults = ['modelResults_', savedNucParSet{iModel}];
            saveNames.dataResults = ['dataResults_', savedNucParSet{iModel}];
            metricsToSave.(saveNames.TSLikelihood) = TSLikelihood;
            metricsToSave.(saveNames.modelResults) = modelResults;
            metricsToSave.(saveNames.dataResults) = dataResults;
            if exist(metricsFile,'file')
                save(metricsFile,'-struct','metricsToSave','-append')
            else
                save(metricsFile,'-struct','metricsToSave')
            end
        end

        BIC = -2*FitTotalError + ...
            length(DUSP1_Model_100nM.fittingOptions.modelVarsToFit)*log(sum(DUSP1_Model_100nM.dataSet.nCells));

        metricsToSave.(saveNames.logP) = FitNucError;
        metricsToSave.(saveNames.ts)   = TSLikelihood;
        metricsToSave.(saveNames.tot)  = FitTotalError;
        metricsToSave.(saveNames.bic)  = BIC;

        if exist(metricsFile,'file')
            save(metricsFile,'-struct','metricsToSave','-append')
        else
            save(metricsFile,'-struct','metricsToSave')
        end

        metricBase = ['DUSP1_', savedNucParSet{iModel}, '_'];
        disp(['Log-Posterior for model ', metricBase, ' = ', ...
            num2str(FitNucError), '(NUC), ', ...
            num2str(TSLikelihood), '(TS), ', ...
            num2str(FitTotalError), '(TOTAL), ', ...
            num2str(BIC), '(BIC)'])

        DUSP1NucLogPosterior(iModel) = FitNucError;
        DUSP1NucTSLogLik(iModel)     = TSLikelihood;
        DUSP1NucTotalScore(iModel)   = FitTotalError;
        DUSP1NucBIC(iModel)          = BIC;

        DUSP1_Model_100nM.parameters(DUSP1_Model_100nM.fittingOptions.modelVarsToFit,:)

        modelFile = ['savedModels/',DUSP1nucModelNames{iModel}];
        saveDcName = [DUSP1nucModelNames{iModel}];
        solnToSave = [];
        solnToSave.(saveDcName) = DUSP1_Model_100nM;
        save(modelFile,'-struct','solnToSave')
    else
        loadedMetrics = load(metricsFile, saveNames.logP, saveNames.ts, saveNames.tot, saveNames.bic);
        logP     = loadedMetrics.(saveNames.logP);
        TSLik    = loadedMetrics.(saveNames.ts);
        NucTSTot = loadedMetrics.(saveNames.tot);
        BIC_tot  = loadedMetrics.(saveNames.bic);

        disp(['Log-Posterior for model ', savedNucParSet{iModel}, ' = ', ...
            num2str(logP), '(NUC), ', ...
            num2str(TSLik), '(TS), ', ...
            num2str(NucTSTot), '(TOTAL), ', ...
            num2str(BIC_tot), '(BIC)'])

        DUSP1NucLogPosterior(iModel) = logP;
        DUSP1NucTSLogLik(iModel)     = TSLik;
        DUSP1NucTotalScore(iModel)   = NucTSTot;
        DUSP1NucBIC(iModel)          = BIC_tot;

        if makeTSPlots
            % Recreate the TS model using the saved best-fit parameters.
            [~,~,DUSP1_Model_100nM] = DUSP1_Model_100nM.solve;
        
            ModelTS = DUSP1_Model_100nM;
            ModelTS.tSpan = unique(allData.time)';
            ModelTS.fittingOptions.logPrior = [];
        
            figHandlesDUSP1NucTS{iModel} = makeDUSP1NucTSPlots( ...
                ModelTS, allData, DUSP1nucModelNames{iModel});
            %figHandlesDusp1TS{iModel} = makeTSPlotsSSA(modelResults,dataResults,ModelTS,4,'pdf');
        end
    end
    % AIC based on the same total objective used for BIC.
    DUSP1NucAIC = 2*numDUSP1nucpars - 2*DUSP1NucTotalScore;

    % Differences relative to the best total score / AIC / BIC.
    [bestTotalScore, iBestTotalScore] = max(DUSP1NucTotalScore);
    [bestAIC, iBestAIC] = min(DUSP1NucAIC);
    [bestBIC, iBestBIC] = min(DUSP1NucBIC);

    DeltaTotalScore = DUSP1NucTotalScore - bestTotalScore;
    PosteriorRatioVsBest = exp(DeltaTotalScore);

    DeltaAIC = DUSP1NucAIC - bestAIC;
    DeltaBIC = DUSP1NucBIC - bestBIC;

    % Approximate Bayes factor from BIC.
    % BF_i_vs_best < 1 means model i is worse than the best-BIC model.
    ApproxBFvsBest_BIC = exp(-0.5*DeltaBIC);

    if makeTSPlots
        save(fullfile('savedResults','DUSP1NucTSFigHandles.mat'), ...
            'figHandlesDUSP1NucTS');
    end

    if computeFano
        % Compute FSP solution means, variances, and Fano factors:
        % Extract probabilities from FSP tensor using stateSpace.states
        sol = DUSP1_Model_100nM.Solutions;
        states = double(sol.stateSpace.states);   % nSpecies x nStates

        [nSpecies, nStates] = size(states);
        nTimes = numel(sol.fsp);

        meanVals = zeros(nTimes, nSpecies);
        varVals  = zeros(nTimes, nSpecies);
        fanoVals = zeros(nTimes, nSpecies);
        massVals = zeros(nTimes, 1);

        for it = 1:nTimes

            pTensor = sol.fsp{it}.p.data;      % sptensor, size e.g. 3 x 3 x 501
            tensorSize = size(pTensor);

            % Convert zero-indexed CME states to one-indexed MATLAB tensor subscripts.
            subs = states' + 1;                % nStates x nSpecies

            % Defensive check.
            for is = 1:nSpecies
                if any(subs(:,is) < 1) || any(subs(:,is) > tensorSize(is))
                    error('State indices exceed tensor dimensions for species %d.', is)
                end
            end

            % Convert multidimensional tensor subscripts to linear indices.
            linInd = sub2ind(tensorSize, subs(:,1), subs(:,2), subs(:,3));

            % Convert sparse tensor to dense vector only through linear indexing.
            % For this size, full conversion is also fine, but this keeps the logic clear.
            pDense = double(pTensor);
            p = pDense(linInd);
            p = p(:);

            massVals(it) = sum(p);

            % Normalize in case there is small FSP truncation / escape loss.
            pNorm = p / sum(p);

            for is = 1:nSpecies
                x = states(is, :)';

                mu = sum(x .* pNorm);
                sig2 = sum((x - mu).^2 .* pNorm);

                meanVals(it, is) = mu;
                varVals(it, is) = sig2;
                fanoVals(it, is) = sig2 / max(mu, eps);
            end
        end

        fspTimes = [];
        for i=1:nTimes
            fspTimes(i) = sol.fsp{i}.time*60;
        end

        if tableCount<1
            % DUSP1 nuclear experimental data Fano factors (need only display once):
            T_data_nuc = table;
            T_data_nuc.Data = repmat("DUSP1 nuc", numel(DUSP1_Model_100nM.dataSet.times), 1);
            T_data_nuc.Time = DUSP1_Model_100nM.dataSet.times(:);
            T_data_nuc.NCells = DUSP1_Model_100nM.dataSet.nCells(:);
            T_data_nuc.Mean = DUSP1_Model_100nM.dataSet.mean(:);
            T_data_nuc.Var = DUSP1_Model_100nM.dataSet.var(:);
            T_data_nuc.Fano = DUSP1_Model_100nM.dataSet.var(:) ./ max(DUSP1_Model_100nM.dataSet.mean(:), eps);
            disp(T_data_nuc)
            tableCount = tableCount + 1;  % display data table only once
        end

        % DUSP1 nuclear FSP solution Fano factors (display for each model called):
        rnaIdxFSP = 3;
        T_fsp_nuc = table;
        T_fsp_nuc.Model = repmat(DUSP1nucModelNames{iModel}, nTimes, 1);
        %T_fsp_nuc.Species = repmat("rna", nTimes, 1);
        T_fsp_nuc.Time = fspTimes';
        %T_fsp_nuc.ProbabilityMass = massVals;
        T_fsp_nuc.Mean = meanVals(:, rnaIdxFSP);
        T_fsp_nuc.Var = varVals(:, rnaIdxFSP);
        T_fsp_nuc.Fano = fanoVals(:, rnaIdxFSP);
        disp(T_fsp_nuc)
    end
end

if DUSP1modelnuc>0
    DUSP1NucModelComparison = table( ...
        DUSP1nucModelNames(:), ...
        numDUSP1nucpars(:), ...
        repmat(nDUSP1Nuc, numel(DUSP1nucModelNames), 1), ...
        DUSP1NucLogPosterior(:), ...
        DUSP1NucTSLogLik(:), ...
        DUSP1NucTotalScore(:), ...
        DeltaTotalScore(:), ...
        PosteriorRatioVsBest(:), ...
        DUSP1NucAIC(:), ...
        DeltaAIC(:), ...
        DUSP1NucBIC(:), ...
        DeltaBIC(:), ...
        ApproxBFvsBest_BIC(:), ...
        LaplaceEvidence(:), ...
        'VariableNames', {'Model','nPars','nCells','LogPosterior_Nuc', ...
        'LogLikelihood_TS','TotalLogPosterior','DeltaTotalLogPosterior', ...
        'PosteriorRatioVsBest','AIC','DeltaAIC','BIC','DeltaBIC', ...
        'ApproxBFvsBest_BIC','LaplaceEvidence'} ...
        );

    disp(DUSP1NucModelComparison)

    save(metricsFile, 'DUSP1NucModelComparison', '-append')

    disp(['Best DUSP1 nuclear model by total score: ', DUSP1nucModelNames{iBestTotalScore}])
    disp(['Best DUSP1 nuclear model by AIC: ', DUSP1nucModelNames{iBestAIC}])
    disp(['Best DUSP1 nuclear model by BIC: ', DUSP1nucModelNames{iBestBIC}])
end

% Best Posterior so far -- 2-State Model model
% N MODEL
% 1 KOFF       -20210.9761(NUC), -4533.2272(TS), -24744.2033(TOTAL), 49547.2536(BIC)  COMPLETE
% 2 KON        -20173.0007(NUC), -4443.4441(TS), -24616.4448(TOTAL), 49291.7366(BIC)  COMPLETE
% 3 KR         -20256.4261(NUC), -4575.3462(TS), -24831.7722(TOTAL), 49722.3915(BIC)  COMPLETE
% 4 AllThree   -20156.6512(NUC), -4454.4794(TS), -24611.1306(TOTAL), 49297.9216(BIC)  COMPLETE
% 5 KON&KOFF   -20156.6833(NUC), -4454.4463(TS), -24611.1296(TOTAL), 49289.5129(BIC)  COMPLETE
% 6 AllThree/0 -20157.6425(NUC), -4453.9342(TS), -24611.5767(TOTAL), 49290.4071(BIC)  COMPLETE
% 7 KON/KOFF/0 -20156.3549(NUC), -4454.7664(TS), -24611.1213(TOTAL), 49281.0896(BIC)  COMPLETE
% 8 KON/0      -20173.7565(NUC), -4442.3907(TS), -24616.1472(TOTAL), 49282.7346(BIC)  COMPLETE

% Based on these results, the affect of GR on KON (burst frequency
% modulation) is much greater than for burst size modulation through KOFF
% (likelihood ratio e^(38) in favor of KON) or KR (likelihood ratio of
% e^(83) in favor of KON). Adding GR control of KOFF in addition to
% the primary control of KON led to a minor improvement of the likelihood
% as well as the Bayesian Information Criterion.
%
% Based on these results, we selected the KON only model for subsequent
% analyses. In this model, KON is changed by the level of GR leading to
% increased frequency of bursts when GR is elevated in the Nucleus.
% However, because we could not exclude the possibility that KOFF and
% KR were also afected, we also retain that alternative model for
% subsequent analyses.

%% STEP 3-SSA -- Fit Parameters via SSA Model.
% In this section, we will fit the various alternative models for
% cytoplasmic DUSP1. Because the full FSP model is too inefficient to use
% for the fitting of all species, we switch to an ABC approach, where the
% fit objective will compare the Nuclear Marginal Distributions, the
% Cytoplasmic Marginal Distributions, and the TS likelihood function.  We
% consider three models of varying levels of complexity.

if ~isempty(DUSP1modelcyt) && ~makePredictions % Skip this if only making predictions.
    [DUSP1_Model_100nM,log10PriorMean,log10PriorStd] = ...
        dusp1ModelLibrary_Final('ModelDUSP1_100nM',false,modelLibrary);

    % Load GR Parameters from Above
    load(savedParsFile,'GRpars');

    % Load DUSP1 Nuc Parameters from above for initial guess. These are default
    % values that will be replaced with actual models later.
    load(savedParsFile,'Pars_KON_KOFF_KR_zeroOFF');

    savedFullParSet = {'FinalModel_cytPars','FinalModel_allButGR','FinalModelNoSaturation',...
        'FinalModelNoTimeVariation','KONModel_allButGR','KONModel_allButGR_NoPrior','FinalModel_allButGR_NoPrior',...
        'Pars_first_order_decay','Pars_GR_DUSP1_TTP_P38_Model',...
        'Pars_GR_DUSP1_TTP_Model_All','Pars_GR_DUSP1_TTP_Model_All_2','Pars_GR_DUSP1_TTP_P38_Model_2'};

    DUSP1cytModelNames = {'FinalModel_cytPars','FinalModel_allButGR','FinalModelNoSaturation',...
        'FinalModelNoTimeVariation','KONModel_allButGR','KONModel_allButGR_NoPrior','FinalModel_allButGR_NoPrior',...
        'First_order_decay','GR_DUSP1_TTP_P38_Model','GR_DUSP1_TTP_Model_All','GR_DUSP1_TTP_Model_All_2','GR_DUSP1_TTP_P38_Model_2'};

    tableCount = 0;

    for iModel = DUSP1modelcyt
        transformSSAsoln = [];
        switch iModel
            case 1 % Kon, Koff, Kr free, use Nuc fit parameters and fit only Cyt Parameters
                [SSAModel_100,log10PriorMean,log10PriorStd] = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                indsFreePars =  [14,15,16,20,21,22];
                load(savedParsFile,'FinalModel_cytPars');
                valsFreePars = FinalModel_cytPars;
                zeroPars = [23];
                includeTS = false;  % Not needed since Cyt parameters do not affect the TS.

            case 2 % Kon, Koff, Kr free. Fit all Parameters
                [SSAModel_100,log10PriorMean,log10PriorStd] = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
                load(savedParsFile,'FinalModel_allButGR');
                valsFreePars = FinalModel_allButGR;
                zeroPars = [23];
                includeTS = true;

            case 3 % No Saturation, All Pars Fit
                [SSAModel_100,log10PriorMean,log10PriorStd] = dusp1ModelLibrary_Final('altSSAModel_NoSaturation_100',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26];
                load(savedParsFile,'FinalModelNoSaturation');
                valsFreePars = FinalModelNoSaturation;
                zeroPars = [23];
                includeTS = true;

            case 4 % No Time Variation, All Pars Fit
                [SSAModel_100,log10PriorMean,log10PriorStd] = dusp1ModelLibrary_Final('altSSAModel_NoTimeVariation_100',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,24,25,26];
                load(savedParsFile,'FinalModelNoTimeVariation');
                valsFreePars = FinalModelNoTimeVariation;
                zeroPars = [23];
                includeTS = true;

            case 5 % KON Only, All Pars Fit
                [SSAModel_100,log10PriorMean,log10PriorStd] = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24];
                load(savedParsFile,'KONModel_allButGR');
                valsFreePars = KONModel_allButGR;
                zeroPars = [23,25,26];
                includeTS = true;

            case 6 % KON Only, All Pars Fit, No Prior (same as 5 but without a prior)
                [SSAModel_100] = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                log10PriorMean =[]; log10PriorStd =[];
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24];
                load(savedParsFile,'KONModel_allButGR_NoPrior');
                valsFreePars = KONModel_allButGR_NoPrior;
                zeroPars = [23,25,26];
                includeTS = true;

            case 7 % Full, All Pars Fit, No Prior (same as 2 but without a prior)
                [SSAModel_100] = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                log10PriorMean =[]; log10PriorStd =[];
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
                load(savedParsFile,'FinalModel_allButGR_NoPrior');
                valsFreePars = FinalModel_allButGR_NoPrior;
                zeroPars = [23];
                includeTS = true;

            case 8 % First Order Decay
                [SSAModel_100] = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                SSAModel_100.propensityFunctions(10) = {'degCyt0*rCyt'};
                log10PriorMean =[]; log10PriorStd =[];
                indsFreePars =  [1,2,3,4,14,19,24,25,26];
                load(savedParsFile,'Pars_first_order_decay');
                valsFreePars = Pars_first_order_decay;
                zeroPars = [15,16,21,22,23];
                includeTS = true;

            case 9 % DO NOT USE
                disp('Invalid Model')
                return
                % [SSAModel_100] = dusp1ModelLibrary_Final('GR_DUSP1_TTP_P38_Model',false,modelLibrary);
                % log10PriorMean =[]; log10PriorStd =[];
                % % indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26,27,28,29,30];
                % indsFreePars = [14,15,27:44];
                % load(savedParsFile,'Pars_GR_DUSP1_TTP_P38_Model');
                % valsFreePars = Pars_GR_DUSP1_TTP_P38_Model;
                % zeroPars = [23];
                % includeTS = false;
                % transformSSAsoln = zeros(6,18);
                % transformSSAsoln(1:6,1:6) = eye(6);
                % transformSSAsoln(6,12) = 1;
                % SSAModel_100.tSpan = [-500,SSAModel_100.dataSet.times];

            case 10  %% Mechanistic model with TTP and Prior
                [SSAModel_100,log10PriorMean,log10PriorStd] = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,19,24,25,26,27:36];
                SSAModel_100.fittingOptions.modelVarsToFit = indsFreePars;
                load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All');
                valsFreePars = Pars_GR_DUSP1_TTP_Model_All;
                zeroPars = [20,21,22,23];
                includeTS = true;
                transformSSAsoln = zeros(6,13);
                transformSSAsoln(1:6,1:6) = eye(6);
                transformSSAsoln(6,12) = 1;
                SSAModel_100.tSpan = [-500,SSAModel_100.dataSet.times];
                
            case 11  %% Mechanistic model with TTP
                [SSAModel_100] = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
                log10PriorMean =[]; log10PriorStd =[];
                indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26,27:36];
                % indsFreePars = [1,2,3,4,14,15,27:36];
                load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All_2');
                valsFreePars = Pars_GR_DUSP1_TTP_Model_All_2;
                zeroPars = [23];
                includeTS = true;
                transformSSAsoln = zeros(6,13);
                transformSSAsoln(1:6,1:6) = eye(6);
                transformSSAsoln(6,12) = 1;
                SSAModel_100.tSpan = [-500,SSAModel_100.dataSet.times];
        end

        if isunix&&~ismac&&iModel<10
            % Temporary fix to prevent C on linux for the models that lead
            % to quiet failure due to nonlinear propensity functions.
            SSAModel_100.ssaOptions.useC = false;
        end

        freePars = savedFullParSet{iModel};

        % Update GR Parameters from first section.
        SSAModel_100.parameters(5:12,2) = num2cell(GRpars);

        % Update Nuc DUSP1 Parameters.
        SSAModel_100.parameters([1,2,3,4,19,24,25,26],2) = num2cell(Pars_KON_KOFF_KR_zeroOFF);
        SSAModel_100.parameters(zeroPars,2) = num2cell(zeros(size(zeroPars)));

        % Update Parameters in TS model.
        ModelTS = DUSP1_Model_100nM;
        ModelTS.dataSet =[];
        ModelTS.parameters([5:12],2) = num2cell(GRpars);
        ModelTS.parameters([1,2,3,4,19,24,25,26],2) = num2cell(Pars_KON_KOFF_KR_zeroOFF);
        ModelTS.parameters(zeroPars,2) = num2cell(zeros(size(zeroPars)));

        % Load data for TS model
        allData = readtable(dataFileDusp1);
        allData = allData(allData.cyto_area_px>=12593&allData.cyto_area_px<=17685&isnan(allData.time_tpl),:);
        ModelTS.tSpan = unique(allData.time)';

        % Set number of sims
        SSAModel_100.solutionScheme = 'ssa';
        SSAModel_100.ssaOptions.nSimsPerExpt = 10000/length(SSAModel_100.tSpan);

        % Set the parameters to be fit.
        SSAModel_100.fittingOptions.modelVarsToFit = indsFreePars;

        % Load guess for cytoplasmic parameters
        SSAModel_100.parameters(indsFreePars,2) = num2cell(valsFreePars);
        ModelTS.fittingOptions.modelVarsToFit = indsFreePars;
        ModelTS.parameters(indsFreePars,2) = num2cell(valsFreePars);

        % Solve once to generate SSA files
        [~,~,SSAModel_100] = SSAModel_100.solve;

        % DEBUG -- show mean of solution
        % mean(squeeze(SSAModel_100.Solutions.trajs(5:6,:,:)),3)'

        modelFile = ['savedModels/',DUSP1cytModelNames{iModel}];
        saveDcName = [DUSP1cytModelNames{iModel}];
        solnToSave = [];
        solnToSave.(saveDcName) = SSAModel_100;
        save(modelFile,'-struct','solnToSave')

        % Define TS likelihood function
        TSLikelihood = @(pars)computeTSlikelihood(pars,ModelTS,allData,50,true);

        % Define total loss function
        weights_ABC = [250, 47.8, 1]; % Weight on the different components of the ABC
        % loss function. This is determined through analysis of the function
        % for repeated evaluations under the same parameter values (see next
        % section).
        [totalDist,Dists] = computeTotalObjFun(valsFreePars,indsFreePars,SSAModel_100,TSLikelihood,...
            log10PriorMean,log10PriorStd,true,savedParsFile,freePars,true,...
            makePlots,NaN,weights_ABC,[1,1],transformSSAsoln,[2,3],[1],[]);

        % Save cytoplasmic model metrics (for when refitDUSP1cyt=false)
        saveNames.jNucCyt = ['JNucCyt_', savedFullParSet{iModel}];
        saveNames.jTS     = ['JTS_',     savedFullParSet{iModel}];
        saveNames.jPrior  = ['JPrior_',  savedFullParSet{iModel}];
        saveNames.jTotal  = ['JTotal_',  savedFullParSet{iModel}];

        metricsToSave = struct();
        metricsToSave.(saveNames.jNucCyt) = Dists(1);
        metricsToSave.(saveNames.jTS)     = Dists(2);
        metricsToSave.(saveNames.jPrior)  = Dists(3);
        metricsToSave.(saveNames.jTotal)  = totalDist;

        if exist(metricsFile, 'file')
            save(metricsFile, '-struct', 'metricsToSave', '-append')
        else
            save(metricsFile, '-struct', 'metricsToSave')
        end

        if refitDUSP1cyt
            if iModel==1||iModel>=8%iModel==8||iModel==9||iModel==10
                defaultTSValue = Dists(2);
            else
                defaultTSValue = NaN;
            end

            % Loss Function
            objAll = @(x)-computeTotalObjFun(x,indsFreePars,SSAModel_100,TSLikelihood,...
                log10PriorMean,log10PriorStd,true,savedParsFile,freePars,includeTS,...
                makePlots,defaultTSValue,weights_ABC,[1,1],transformSSAsoln,[2,3],[1],[]);

            MHFitOptions.obj = objAll;
            MHFitOptions.logForm = true;

            % eval(['minerr_',freePars,' = inf;'])
            % save(savedParsFile,['minerr_',freePars],'-append')

            scaleMH = 1;
            isTuning = true;
            isFinal = false;
            accept = 0;
            while isTuning||isFinal
                if ~isFinal
                    MHFitOptions.numberOfSamples=200;
                    MHFitOptions.thin=5;
                else
                    MHFitOptions.numberOfSamples=10000;
                    MHFitOptions.thin=5;
                end

                load(savedParsFile,['covPost_',freePars])
                try
                    covPost = scaleMH*eval(['covPost_',freePars])+1e-6*eye(length(valsFreePars));
                catch
                    covPost = scaleMH*0.0001*eye(length(valsFreePars));
                end
                MHFitOptions.proposalDistribution=@(x)x+mvnrnd(0*x,covPost+1e-6*eye(length(x)));

                MHFitOptions.saveFile = ['TMPMH',freePars,'.mat'];
                delete(MHFitOptions.saveFile)

                MHFitOptions.progress = makePlots;
                [valsFreePars,~,MHResultsAll] = SSAModel_100.maximizeLikelihood(valsFreePars',MHFitOptions,'MetropolisHastings');
                delete(MHFitOptions.saveFile)

                % Only update covPost if there are more accepted samples
                % than there are paramters -- otherwise, it will be
                % underdetermined artificially.
                if MHResultsAll.mhAcceptance*length(MHResultsAll.mhValue)>size(MHResultsAll.mhSamples,2)
                    covPost = cov(MHResultsAll.mhSamples);
                    eval([freePars,'=valsFreePars;']);
                    eval(['covPost_',freePars,'=covPost;']);
                    save(savedParsFile,['covPost_',freePars],freePars,'-append');
                end

                disp(['Tuning acceptance rate: ',num2str(MHResultsAll.mhAcceptance)])

                if isFinal
                    save(['savedParameters/MHResults_',freePars],'MHResultsAll')
                    disp('Metropolis Hastings is Complete')
                    break
                elseif MHResultsAll.mhAcceptance<0.05
                    scaleMH = scaleMH*0.2;
                elseif MHResultsAll.mhAcceptance<0.2
                    scaleMH = scaleMH*0.75;
                elseif MHResultsAll.mhAcceptance>0.6
                    scaleMH = scaleMH*3;
                elseif MHResultsAll.mhAcceptance>0.45
                    scaleMH = scaleMH*1.5;
                elseif isTuning&&~isFinal
                    isFinal = true;
                end
            end
            %save(metricsFile, 'DUSP1CytModelComparison', '-append')
        else
            saveNames.jNucCyt = ['JNucCyt_', savedFullParSet{iModel}];
            saveNames.jTS     = ['JTS_', savedFullParSet{iModel}];
            saveNames.jPrior  = ['JPrior_', savedFullParSet{iModel}];
            saveNames.jTotal  = ['JTotal_', savedFullParSet{iModel}];
            loadedMetrics = load(metricsFile, saveNames.jNucCyt, saveNames.jTS, saveNames.jPrior, saveNames.jTotal);
            JNucCyt = loadedMetrics.(saveNames.jNucCyt);
            JTS     = loadedMetrics.(saveNames.jTS);
            JPrior  = loadedMetrics.(saveNames.jPrior);
            JTotal  = loadedMetrics.(saveNames.jTotal);

            disp([savedFullParSet{iModel},': J_NucCyt=',num2str(JNucCyt),'; J_TS=',...
                num2str(JTS),'; J_Prior=', num2str(JPrior),'; J_Total=', num2str(JTotal)]);

            load(['savedParameters/MHResults_',freePars],'MHResultsAll')
            disp(['Tuning MH acceptance rate: ',num2str(MHResultsAll.mhAcceptance)])
        end

        if computeFano
            if tableCount<1
                % Experimental DUSP1 cytoplasmic Fano factors
                T_data_cyt = table;
                T_data_cyt.Data = repmat("DUSP1 cyt", numel(SSAModel_100.dataSet.times), 1);
                T_data_cyt.Time = SSAModel_100.dataSet.times(:);
                T_data_cyt.NCells = SSAModel_100.dataSet.nCells(:);
                T_data_cyt.Mean1 = SSAModel_100.dataSet.mean(:,1);
                T_data_cyt.Mean2 = SSAModel_100.dataSet.mean(:,2);
                T_data_cyt.Var1 = SSAModel_100.dataSet.var(:,1);
                T_data_cyt.Var2 = SSAModel_100.dataSet.var(:,2);
                T_data_cyt.Fano1 = SSAModel_100.dataSet.var(:,1) ./ max(SSAModel_100.dataSet.mean(:,1), eps);
                T_data_cyt.Fano2 = SSAModel_100.dataSet.var(:,2) ./ max(SSAModel_100.dataSet.mean(:,2), eps);
                disp(T_data_cyt)
                tableCount = tableCount + 1;  % display data table only once
            end
        end
    end
end

% Best Fits Found so Far:
% FinalModel_allButGR:           J_NucCyt=-148.9822; J_TS=-87.0719; J_Prior=-13.5222; J_Total=249.5763
% FinalModelNoSaturation:        J_NucCyt=-267.393;  J_TS=-89.9993; J_Prior=-14.029;  J_Total=371.4212
% FinalModelNoTimeVariation:     J_NucCyt=-243.112;  J_TS=-94.9107; J_Prior=-13.4861; J_Total=351.5088
% KONModel_allButGR:             J_NucCyt=-148.7916; J_TS=-86.7519; J_Prior=-5.2799;  J_Total=240.8234
% KONModel_allButGR_NoPrior:     J_NucCyt=-142.0278; J_TS=-86.527;  J_Prior=0;        J_Total=228.5548
% FinalModel_allButGR_NoPrior:   J_NucCyt=-139.8497; J_TS=-86.4468; J_Prior=0;        J_Total=226.2965
% Pars_GR_DUSP1_TTP_Model_All_2: J_NucCyt=-141.6961; J_TS=-92.7881; J_Prior=0;        J_Total=234.4842

% Based on these results, we retain the last three models (6,7,11) to make
% predictions for other data.
% We kept Model 7 (full model no prior) because it provided the best
% overall fit to the data.
% We kept Model 6 (Kon) because it provided nearly as good a fit with less
% complexity and therefore less likelihood of overfitting.
% We kept Model 11 because it provides a reasonably strong fit, but with a
% more mechanistic understanding for the TTP reactions.


%% Determine what weights to use on SSA ABC Loss function.
% % In this section, we run many independent sets of SSAs with the same
% % parameter value to determine the expected variation in the ABC objective
% % function.  This is then used to calculate and assign a weight on the
% % approximate likelihood function for the Nuc and Cyt distributions.  In
% % this case, we scale so that the expected deviation is approximately
% % one.  Note that the TS log-likelihood is calculated using FSP and is
% % deterministic, and it does not need to be scaled.
% % This section only needs to be run once after finding a reasonable
% % parameter value, and we will assume that the weight will remain the same
% % for other parameters.  We can confirm later by re-running after finding a
% % best fit to the parameters and check that the weight does not need to
% % changed appreciably.
%
% % Determine spread of the ABC constraint
% weights = [1,1,1];
% for k = 1:100
%     [totalDist,DistsRand(k,:)] = computeTotalObjFun(valsFreePars,indsFreePars,SSAModel_100,TSLikelihood,...
%         log10PriorMean,log10PriorStd,true,savedParsFile,freePars,false,...
%         makePlots,defaultTSValue,weights,[0,1],transformSSAsoln,[2,3],[1],[]);
% end
% 
% weight_ABC = std(DistsRand(:,1));

%% Determine spread of the FSP Likelihood.
% % Load nuclear model
% [DUSP1_Model_100nM] = dusp1ModelLibrary_Final('ModelDUSP1_100nM',false,modelLibrary);
% 
% % Load and update GR Parameters from previous section.
% load(savedParsFile,'GRpars');
% DUSP1_Model_100nM.parameters(5:12,2) = num2cell(GRpars);
% 
% load(savedParsFile,'Pars_KON_KOFF_KR_zeroOFF');
% DUSP1_Model_100nM.parameters([1,2,3,4,19,24,25,26],2) = num2cell(Pars_KON_KOFF_KR_zeroOFF);
% DUSP1_Model_100nM.parameters(23,2) = {0};
% 
% [~,~,DUSP1_Model_100nM] = DUSP1_Model_100nM.solve;
% 
% DUSP1_Model_100nM.fittingOptions.logPrior = [];
% [nucLikelihoodSpread,nucLikelihoodVec] = DUSP1_Model_100nM.estimateLikelihoodSpread(500);
% 
% % Set the ABC weight to the ratio of the ABC variability to the Nuclear Log
% % Likelihood variability.
% weights_ABC = [weight_ABC, nucLikelihoodSpread, 1];
% % Computed values: [250, 47.8, 1]


%% STEP 4-TRP -- Fit the Tryptolide Rate

if ~isempty(finalDUSP1model)
    % Load model for TPL and update to best fit parameters
    ModelTPl = dusp1ModelLibrary_Final('ModelTPl_0min',false,modelLibrary);
    dataTptl = ModelTPl.dataSet;

    load(savedParsFile,'GRpars','FinalModel_allButGR','KONModel_allButGR',...
        'KONModel_allButGR_NoPrior','FinalModel_allButGR_NoPrior',...
        'Pars_GR_DUSP1_TTP_P38_Model_2');
    transformSSAsoln = [];
    switch finalDUSP1model
        case 2
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
            zeroPars = 23;
            valsFreePars = FinalModel_allButGR;
            load(savedParsFile,'ktptl_FinalModel_allButGR');
            partKtptl = 'ktptl_FinalModel_allButGR';
            ktptl = ktptl_FinalModel_allButGR;
        case 3 % No Saturation, All Pars Fit
            [SSAModel_100] = dusp1ModelLibrary_Final('altSSAModel_NoSaturation_100',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26];
            load(savedParsFile,'FinalModelNoSaturation');
            valsFreePars = FinalModelNoSaturation;
            zeroPars = [23];
            SSAModel_100.tSpan = [-500,SSAModel_100.dataSet.times];
            load(savedParsFile,'ktptl_FinalModelNoSaturation');
            partKtptl = 'ktptl_FinalModelNoSaturation';
            ktptl = ktptl_FinalModelNoSaturation;
            ModelTPl = SSAModel_100;
            ModelTPl.dataSet = dataTptl;

        case 4 % No Time Variation, All Pars Fit
            [SSAModel_100] = dusp1ModelLibrary_Final('altSSAModel_NoTimeVariation_100',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,24,25,26];
            load(savedParsFile,'FinalModelNoTimeVariation');
            valsFreePars = FinalModelNoTimeVariation;
            zeroPars = [23];
            SSAModel_100.tSpan = [-500,SSAModel_100.dataSet.times];
            load(savedParsFile,'ktptl_FinalModelNoTimeVariation');
            partKtptl = 'ktptl_FinalModelNoTimeVariation';
            ktptl = ktptl_FinalModelNoTimeVariation;
            ModelTPl = SSAModel_100;
            ModelTPl.dataSet = dataTptl;

        case 5
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24];
            zeroPars = [23,25,26];
            valsFreePars = KONModel_allButGR;
            load(savedParsFile,'ktptl_KONModel_allButGR');
            partKtptl = 'ktptl_KONModel_allButGR';
            ktptl = ktptl_KONModel_allButGR;
        case 6
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24];
            zeroPars = [23,25,26];
            valsFreePars = KONModel_allButGR_NoPrior;
            load(savedParsFile,'ktptl_KONModel_allButGR_NoPrior');
            partKtptl = 'ktptl_KONModel_allButGR_NoPrior';
            ktptl = ktptl_KONModel_allButGR_NoPrior;
        case 7
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
            zeroPars = 23;
            valsFreePars = FinalModel_allButGR_NoPrior;
            load(savedParsFile,'ktptl_FinalModel_allButGR_NoPrior');
            partKtptl = 'ktptl_FinalModel_allButGR_NoPrior';
            ktptl = ktptl_FinalModel_allButGR_NoPrior;
        case 8 % First Order Decay
            indsFreePars =  [1,2,3,4,14,19,24,25,26];
            zeroPars = [15,16,21,22,23];
            load(savedParsFile,'Pars_first_order_decay');
            valsFreePars = Pars_first_order_decay;
            ModelTPl.propensityFunctions(10) = {'degCyt0*rCyt'};
            ktptl = Pars_first_order_decay;
        case 10  %% Mechanistic model with TTP (with Prior)
            [SSAModel_100] = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,19,24,25,26,27:36];
            SSAModel_100.fittingOptions.modelVarsToFit = indsFreePars;
            load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All');
            valsFreePars = Pars_GR_DUSP1_TTP_Model_All;
            zeroPars = [20,21,22,23];
            transformSSAsoln = zeros(6,13);
            transformSSAsoln(1:6,1:6) = eye(6);
            transformSSAsoln(6,12) = 1;
            SSAModel_100.tSpan = [-500,SSAModel_100.dataSet.times];
            load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All');
            partKtptl = 'ktptl_GR_DUSP1_TTP_Model_All';
            ktptl = ktptl_GR_DUSP1_TTP_Model_All;
            ModelTPl = SSAModel_100;
            ModelTPl.dataSet = dataTptl;
        case 11  %% Mechanistic model with TTP
            [SSAModel_100] = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26,27:36];
            load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All_2');
            valsFreePars = Pars_GR_DUSP1_TTP_Model_All_2;
            zeroPars = [23];
            transformSSAsoln = zeros(6,13);
            transformSSAsoln(1:6,1:6) = eye(6);
            transformSSAsoln(6,12) = 1;
            SSAModel_100.tSpan = [-500,SSAModel_100.dataSet.times];
            load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All_2');
            partKtptl = 'ktptl_GR_DUSP1_TTP_Model_All_2';
            ktptl = ktptl_GR_DUSP1_TTP_Model_All_2;
            ModelTPl = SSAModel_100;
            ModelTPl.dataSet = dataTptl;
        % case 12  %% Mechanistic model with TTP and P38
            % [SSAModel_100] = dusp1ModelLibrary_Final('GR_DUSP1_TTP_P38_Model_2',false,modelLibrary);
            % indsFreePars = [1,2,3,4,14,15,19,20,21,22,24:44];
            % valsFreePars = Pars_GR_DUSP1_TTP_P38_Model_2;
            % zeroPars = [23];
            % transformSSAsoln = zeros(6,18);
            % transformSSAsoln(1:6,1:6) = eye(6);
            % transformSSAsoln(6,12) = 1;
            % SSAModel_100.tSpan = [-500,SSAModel_100.dataSet.times];
            % load(savedParsFile,'ktptl_GR_DUSP1_TTP_P38_Model_2');
            % partKtptl = 'ktptl_GR_DUSP1_TTP_P38_Model_2';
            % ktptl = ktptl_GR_DUSP1_TTP_P38_Model_2;
            % ModelTPl = SSAModel_100;
            % ModelTPl.dataSet = dataTptl;
    end
    ModelTPl.parameters(5:12,2) = num2cell(GRpars);
    ModelTPl.parameters(indsFreePars,2) = num2cell(valsFreePars);
    ModelTPl.parameters(zeroPars,2) = num2cell(0*zeroPars);

    ModelTPl.ssaOptions.nSimsPerExpt = 10000/length(ModelTPl.tSpan);

    % Load new parameter for tryptolide diffusion, and fit if requested.
    ModelTPl.fittingOptions.modelVarsToFit = 18;
    ModelTPl.fittingOptions.logPrior = [];

    if refitKTPTL % run fit only for the Triptolide infusion rate
        eval(['minerr_',partKtptl,' = inf;']);
        save(savedParsFile,['minerr_',partKtptl],'-append')
        objAll = @(x)(computeCytError(x,[18],ModelTPl,true,savedParsFile, ...
            false,[],partKtptl,[0,1,0,0],false,transformSSAsoln,[2,3],[1],[]));

        objAll(ktptl)

        fitOptionsTpl = fitOptions;
        fitOptionsTpl.MaxIter = 20;
        ktptl = fminsearch(objAll,ktptl,fitOptions);
    end
    ModelTPl.parameters{18,2} = ktptl;
end

%% STEP 5-PRED -- Test SSA Model on Prediction Data for other Dex Concentrations
% This section will make predictions for the held out 0.3, 1, and 10nM Dex
% DUSP1 data.
if ~isempty(DUSP1modelcyt) && makePredictions

    combined_GRModel = dusp1ModelLibrary_Final('combinedGRModel',false,modelLibrary, ...
        dataFileGR,dataFileDusp1);
    load(savedParsFile,'GRpars')
    combined_GRModel = combined_GRModel.updateModels(GRpars, false);
    GRMod = combined_GRModel.SSITModels{3};

    % Load data sets for all conditions
    dexA = {'0p3','1','10','100'};
    dexAn = [0.3,1,10,100];
    dataSets = cell(1,4);
    for iDex = 1:4
        TMPMod = dusp1ModelLibrary_Final(['fullSSAModel_',dexA{iDex},'_2StateGen'],false,modelLibrary);
        dataSets{iDex} = TMPMod.dataSet;

        % Determine a
        GRMod.parameters{13,2} = dexAn(iDex);
        soln{1} = GRMod.solve;
        for i = 1:7
            P = sum(double(soln{1}.fsp{i}.p.data),1)';
            GRNucScale(i,iDex) = [0:length(P)-1]*P;
        end
    end
    GRNucScale = mean(GRNucScale)./min(GRNucScale)-1;

    DUSP1_Model_100nM = dusp1ModelLibrary_Final('ModelDUSP1_100nM',false,modelLibrary);

    % Load GR Parameters from Above
    load(savedParsFile,'GRpars');

    % Load DUSP1 Nuc Parameters from above for initial guess. These are default
    % values that will be replaced with actual models later.
    load(savedParsFile,'Pars_KON_KOFF_KR_zeroOFF');

    savedFullParSet = {'FinalModel_cytPars','FinalModel_allButGR','FinalModelNoSaturation',...
        'FinalModelNoTimeVariation','KONModel_allButGR','KONModel_allButGR_NoPrior','FinalModel_allButGR_NoPrior',...
        'Pars_first_order_decay','Pars_GR_DUSP1_TTP_P38_Model',...
        'Pars_GR_DUSP1_TTP_Model_All','Pars_GR_DUSP1_TTP_Model_All_2','Pars_GR_DUSP1_TTP_P38_Model_2'};

    for iModel = DUSP1modelcyt
        transformSSAsoln =[];
        switch iModel
            case 1 % Full, Cyt Pars Fit
                SSAModel = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                indsFreePars =  [14,15,16,20,21,22];
                load(savedParsFile,'FinalModel_cytPars');
                valsFreePars = FinalModel_cytPars;
                zeroPars = [23];

            case 2 % Full, All Pars Fit
                SSAModel = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
                load(savedParsFile,'FinalModel_allButGR');
                valsFreePars = FinalModel_allButGR;
                zeroPars = [23];
                load(savedParsFile,'ktptl_FinalModel_allButGR');
                ktptl = ktptl_FinalModel_allButGR;

            case 3 % No Saturation, All Pars Fit
                SSAModel = dusp1ModelLibrary_Final('altSSAModel_NoSaturation_100',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26];
                load(savedParsFile,'FinalModelNoSaturation');
                valsFreePars = FinalModelNoSaturation;
                zeroPars = [23];
                load(savedParsFile,'ktptl_FinalModelNoSaturation');
                ktptl = ktptl_FinalModelNoSaturation;

            case 4 % No Time Variation, All Pars Fit
                SSAModel = dusp1ModelLibrary_Final('altSSAModel_NoTimeVariation_100',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,24,25,26];
                load(savedParsFile,'FinalModelNoTimeVariation');
                valsFreePars = FinalModelNoTimeVariation;
                zeroPars = [23];
                load(savedParsFile,'ktptl_FinalModelNoTimeVariation');
                ktptl = ktptl_FinalModelNoTimeVariation;

            case 5 % KON Only, All Pars Fit
                SSAModel = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24];
                load(savedParsFile,'KONModel_allButGR');
                valsFreePars = KONModel_allButGR;
                zeroPars = [23,25,26];
                load(savedParsFile,'ktptl_KONModel_allButGR');
                ktptl = ktptl_KONModel_allButGR;

            case 6 % KON Only, All Pars Fit, No Prior
                [SSAModel] = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24];
                load(savedParsFile,'KONModel_allButGR_NoPrior');
                valsFreePars = KONModel_allButGR_NoPrior;
                zeroPars = [23,25,26];
                load(savedParsFile,'ktptl_KONModel_allButGR_NoPrior');
                ktptl = ktptl_KONModel_allButGR_NoPrior;

            case 7 % Full, All Pars Fit, No Prior
                [SSAModel] = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
                load(savedParsFile,'FinalModel_allButGR_NoPrior');
                valsFreePars = FinalModel_allButGR_NoPrior;
                zeroPars = [23];
                load(savedParsFile,'ktptl_FinalModel_allButGR_NoPrior');
                ktptl = ktptl_FinalModel_allButGR_NoPrior;

            case 8 % First Order Decay
                [SSAModel] = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
                SSAModel.propensityFunctions(10) = {'degCyt0*rCyt'};
                indsFreePars =  [1,2,3,4,14,19,24,25,26];
                load(savedParsFile,'Pars_first_order_decay');
                valsFreePars = Pars_first_order_decay;
                zeroPars = [15,16,21,22,23];
                load(savedParsFile,'ktptl_Pars_first_order_decay');
                ktptl = ktptl_Pars_first_order_decay;

            case 10  %% Mechanistic model with TTP (with prior)
                SSAModel = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,19,24,25,26,27:36];
                load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All');
                valsFreePars = Pars_GR_DUSP1_TTP_Model_All;
                zeroPars = [20,21,22,23];
                transformSSAsoln = zeros(6,13);
                transformSSAsoln(1:6,1:6) = eye(6);
                transformSSAsoln(6,12) = 1;
                SSAModel.tSpan = [-500,SSAModel.dataSet.times];
                load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All');
                ktptl = ktptl_GR_DUSP1_TTP_Model_All;

            case 11  %% Mechanistic model with TTP
                SSAModel = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26,27:36];
                % indsFreePars = [1,2,3,4,14,15,27:36];
                load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All_2');
                valsFreePars = Pars_GR_DUSP1_TTP_Model_All_2;
                zeroPars = [23];
                transformSSAsoln = zeros(6,13);
                transformSSAsoln(1:6,1:6) = eye(6);
                transformSSAsoln(6,12) = 1;
                SSAModel.tSpan = [-500,SSAModel.dataSet.times];
                load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All_2');
                ktptl = ktptl_GR_DUSP1_TTP_Model_All_2;

            case 12  %% Mechanistic model with TTP and P38
                SSAModel = dusp1ModelLibrary_Final('GR_DUSP1_TTP_P38_Model_2',false,modelLibrary);
                indsFreePars = [1,2,3,4,14,15,19,20,21,22,24:44];
                load(savedParsFile,'Pars_GR_DUSP1_TTP_P38_Model_2');
                valsFreePars = Pars_GR_DUSP1_TTP_P38_Model_2;
                zeroPars = [23];
                transformSSAsoln = zeros(6,18);
                transformSSAsoln(1:6,1:6) = eye(6);
                transformSSAsoln(6,12) = 1;
                SSAModel.tSpan = [-500,SSAModel.dataSet.times];
                load(savedParsFile,'ktptl_GR_DUSP1_TTP_P38_Model_2');
                ktptl = ktptl_GR_DUSP1_TTP_P38_Model_2;

        end

        freePars = savedFullParSet{iModel};
        tplModelNames = {'ModelTPl_0min','ModelTPl_20min','ModelTPl_75min','ModelTPl_150min','ModelTPl_180min'};
        tplArr = {'0min','20min','75min','150min','180min'};

        if recomputeSSA
            % Update GR Parameters from first section.
            SSAModel.parameters(5:12,2) = num2cell(GRpars);

            % Update Nuc DUSP1 Parameters.
            % These are defaults that may be overwritten later.
            SSAModel.parameters([1,2,3,4,19,24,25,26],2) = num2cell(Pars_KON_KOFF_KR_zeroOFF);
            SSAModel.parameters(zeroPars,2) = num2cell(zeros(size(zeroPars)));

            % Update Parameters in TS model.
            ModelTS = DUSP1_Model_100nM;
            ModelTS.dataSet =[];
            ModelTS.parameters([5:12],2) = num2cell(GRpars);
            ModelTS.parameters([1,2,3,4,19,24,25,26],2) = num2cell(Pars_KON_KOFF_KR_zeroOFF);
            ModelTS.parameters(zeroPars,2) = num2cell(zeros(size(zeroPars)));

            % Load data for TS model
            allData = readtable(dataFileDusp1);
            allData = allData(allData.cyto_area_px>=12593&allData.cyto_area_px<=17685&isnan(allData.time_tpl),:);
            ModelTS.tSpan = unique(allData.time)';

            % Set number of sims
            SSAModel.ssaOptions.nSimsPerExpt = 10000/length(SSAModel.tSpan);

            % Solve once to generate SSA files
            % [~,~,SSAModel] = SSAModel.solve;

            % Set the parameters to be fit.
            SSAModel.fittingOptions.modelVarsToFit = indsFreePars;

            % Load guess for cytoplasmic parameters
            SSAModel.parameters(indsFreePars,2) = num2cell(valsFreePars);
            ModelTS.fittingOptions.modelVarsToFit = indsFreePars;
            ModelTS.parameters(indsFreePars,2) = num2cell(valsFreePars);

            weights_ABC = [250, 47.8, 1]; % Weight on the different components of the ABC
            % loss function.

            for iDex = 1:4
                ModelTS.parameters{13,2} = dexAn(iDex);
                SSAModel.parameters{13,2} = dexAn(iDex);
                SSAModel.dataSet = dataSets{iDex};

                if iModel<=7
                    ITTPscale = GRNucScale(iDex)/GRNucScale(4);

                    SSAModel.inputExpressions{2,2} = ...
                        ['1+TTP1*(',num2str(ITTPscale),')*(t^eta/(t^eta+tTTP^eta))*(t>0)'];
                end

                % Define TS likelihood function
                TSLikelihood = @(pars)computeTSlikelihood(pars,ModelTS,allData,50,true);

                % Define total loss function
                [totalDist,Dists] = computeTotalObjFun(valsFreePars,indsFreePars,...
                    SSAModel,TSLikelihood,[],[],false,[],freePars,true,...
                    false,NaN,weights_ABC,[1,1],transformSSAsoln,[2,3],[1],[]);

                disp([savedFullParSet{iModel},', Dex = ',dexA{iDex},' nM: J_NucCyt=',num2str(Dists(1)),'; J_TS=',num2str(Dists(2)),...
                    '; J_Total=',num2str(totalDist)]);

                % Save Dex response prediction metrics (for when recomputeSSA=false)
                metricBase = ['Predict_', savedFullParSet{iModel}, '_Dex_', dexA{iDex}];
                
                saveNames.jNucCyt = ['JNucCyt_', metricBase];
                saveNames.jTS     = ['JTS_',     metricBase];
                saveNames.jTotal  = ['JTotal_',  metricBase];
                
                metricsToSave = struct();
                metricsToSave.(saveNames.jNucCyt) = Dists(1);
                metricsToSave.(saveNames.jTS)     = Dists(2);
                metricsToSave.(saveNames.jTotal)  = totalDist;
                
                if exist(metricsFile, 'file')
                    save(metricsFile, '-struct', 'metricsToSave', '-append')
                else
                    save(metricsFile, '-struct', 'metricsToSave')
                end
            end

            % Now make TPL predictions
            for iTPL = 1:5
                if ~exist('tplDat','var')||length(tplDat)<iTPL
                    tmpModel = dusp1ModelLibrary_Final(tplModelNames{iTPL},false,modelLibrary);
                    tplDat{iTPL} = tmpModel.dataSet;
                end
                SSAModel.dataSet = tplDat{iTPL};
                SSAModel.parameters([1,2,3,4,19,24,25,26],2) = num2cell(Pars_KON_KOFF_KR_zeroOFF);
                SSAModel.parameters(indsFreePars,2) = num2cell(valsFreePars);
                SSAModel.parameters(zeroPars,2) = num2cell(zeros(size(zeroPars)));
                ModelTS.parameters{13,2} = 100;
                SSAModel.parameters{13,2} = 100;

                %% Remove all but the last 4 time pints (after TPL)
                SSAModel.dataSet.app.DataLoadingAndFittingTabOutputs.dataTensor = ...
                    SSAModel.dataSet.app.DataLoadingAndFittingTabOutputs.dataTensor(end-3:end,:,:);

                SSAModel.dataSet.nCells = SSAModel.dataSet.nCells(end-3:end);
                SSAModel.dataSet.times = SSAModel.dataSet.times(end-3:end);
                SSAModel.dataSet.mean = SSAModel.dataSet.mean(end-3:end);
                SSAModel.dataSet.var = SSAModel.dataSet.var(end-3:end);
                % Define total loss function
                [totalDist,Dists] = computeTotalObjFun(valsFreePars,indsFreePars,...
                    SSAModel,[],[],[],false,[],freePars,false,...
                    false,0,weights_ABC,[1,1],transformSSAsoln,[2,3],[1],[]);

                disp([savedFullParSet{iModel},', Tpl = ',tplArr{iTPL},' nM: J_NucCyt=',num2str(Dists(1)),...
                    '; J_TS=',num2str(Dists(2)), '; J_Total=',num2str(totalDist)]);

                % Save TPL prediction metrics (for when recomputeSSA=false)
                TPLBase = ['Predict_', savedFullParSet{iModel}, '_Tpl_', tplArr{iTPL}];
                
                saveNames.jNucCyt = ['JNucCyt_', TPLBase];
                saveNames.jTS     = ['JTS_',     TPLBase];
                saveNames.jTotal  = ['JTotal_',  TPLBase];
                
                metricsToSave = struct();
                metricsToSave.(saveNames.jNucCyt) = Dists(1);
                metricsToSave.(saveNames.jTS)     = Dists(2);
                metricsToSave.(saveNames.jTotal)  = totalDist;
                
                if exist(metricsFile, 'file')
                    save(metricsFile, '-struct', 'metricsToSave', '-append')
                else
                    save(metricsFile, '-struct', 'metricsToSave')
                end                
            end
            % else
            %     disp('Triptolide predictions are currently skipped for complex models.')
            % end
        else
            % Dex prediction metrics
            predictBase = ['Predict_', savedFullParSet{iModel}, '_Dex_', dexA{iDex}];
            saveNames.jNucCyt = ['JNucCyt_', predictBase];
            saveNames.jTS     = ['JTS_', predictBase];
            saveNames.jTotal  = ['JTotal_', predictBase];

            loadedMetrics = load(metricsFile, saveNames.jNucCyt, saveNames.jTS, saveNames.jTotal);
            JNucCyt = loadedMetrics.(saveNames.jNucCyt);
            JTS     = loadedMetrics.(saveNames.jTS);
            JTotal  = loadedMetrics.(saveNames.jTotal);

            disp([savedFullParSet{iModel}, ', Dex = ', dexA{iDex}, ' nM: J_NucCyt=', ...
                num2str(JNucCyt), '; J_TS=', num2str(JTS), '; J_Total=', num2str(JTotal)]);

            % TPL prediction metrics
            iTPL=5;
            predictBase = ['Predict_', savedFullParSet{iModel}, '_Tpl_', tplArr{iTPL}];
            saveNames.jNucCyt = ['JNucCyt_', predictBase];
            saveNames.jTS     = ['JTS_', predictBase];
            saveNames.jTotal  = ['JTotal_', predictBase];

            loadedMetrics = load(metricsFile, saveNames.jNucCyt, saveNames.jTS, saveNames.jTotal);
            JNucCyt = loadedMetrics.(saveNames.jNucCyt);
            JTS     = loadedMetrics.(saveNames.jTS);
            JTotal  = loadedMetrics.(saveNames.jTotal);

            disp([savedFullParSet{iModel}, ', Tpl = ', tplArr{iTPL}, ' nM: J_NucCyt=', ...
                num2str(JNucCyt), '; J_TS=', num2str(JTS), '; J_Total=', num2str(JTotal)]);
        end
        Parameters{iModel} = SSAModel.parameters;
    end
else
    Parameters = [];
end
% Best Predictions Found so Far:

% Model 6 - KON only.
% KONModel_allButGR_NoPrior, Dex = 0p3 nM: J_NucCyt=-65.101; J_TS=-20.5233; J_Total=85.6242
