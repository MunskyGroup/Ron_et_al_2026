%% STEP 6-PLOT -- Make plots of final fits and predictions.
% Here we make plots of the final fits and predictions using the

%%    Make DUSP1 Nuc and Cyt Plots using Best Fit Parameter Set
if makePlots && ~isempty(finalDUSP1model)

    if finalDUSP1model<=8
        % Use GR Model to determine scaling factor for TTP effect.  This is
        % calculated by solving GR model for each Dex concentration to make
        % a matrix of mean nuclear GR vs time and Dex (GRNuc), then
        % averaging over time, then dividing by the minimum nuc GR
        % value, then subtracting 1 to get the modifier. 
        % Later this will be reversed -- apply the modifier to scale the
        % time varying component and add 1 to get the total effect.
        combined_GRModel = dusp1ModelLibrary_Final('combinedGRModel',false,modelLibrary, ...
            dataFileGR,dataFileDusp1);
        combined_GRModel = combined_GRModel.updateModels(GRpars, false);
        clear GRNuc
        for j = 1:4
            if j>1
                Mod = combined_GRModel.SSITModels{j-1};
            else
                Mod = combined_GRModel.SSITModels{3};
                Mod.parameters{13,2} = 0.3;
            end
            soln{j} = Mod.solve;
            for i = 1:7
                P = sum(double(soln{j}.fsp{i}.p.data),1)';
                GRNuc(i,j) = [0:length(P)-1]*P;
            end
        end
        GRNucScale = mean(GRNuc)./min(GRNuc)-1;
    end

    fullModelNames = {'fullSSAModel_0p3_2StateGen','fullSSAModel_1_2StateGen',...
        'fullSSAModel_10_2StateGen','fullSSAModel_100_2StateGen'};

    savedFullParSet = {'FinalModel_cytPars','FinalModel_allButGR','FinalModelNoSaturation',...
        'FinalModelNoTimeVariation','KONModel_allButGR','KONModel_allButGR_NoPrior','FinalModel_allButGR_NoPrior',...
        'Pars_first_order_decay','Pars_GR_DUSP1_TTP_P38_Model',...
        'Pars_GR_DUSP1_TTP_Model_All','Pars_GR_DUSP1_TTP_Model_All_2','Pars_GR_DUSP1_TTP_P38_Model_2'};

    figHandlesSSA = cell(4,5);
    ssaSoln = cell(1,4);
    for iModel = 1:4
        % Load Model with Data -- will later replace with current model.
        fullSSAModel = dusp1ModelLibrary_Final(fullModelNames{iModel},false,modelLibrary);
        titrDat{iModel} = fullSSAModel.dataSet;
        dexPar = fullSSAModel.parameters(13,:);

        % Adjust SSA model to account for DEX concentration effect on TTP.
        % For this, we assume the same relative effect as already
        % identified for the effect of DEX on the GR signal.  Since we
        % already fit the data at 100nM Dex, we will scale relative to that
        % ammount.

        if finalDUSP1model<=8
            ITTPscale = GRNucScale(iModel)/GRNucScale(4);

            fullSSAModel.inputExpressions{2,2} = ...
                ['1+TTP1*(',num2str(ITTPscale),')*(t^eta/(t^eta+tTTP^eta))*(t>0)'];
        end

        % Update parameters
        load(savedParsFile,'GRpars','FinalModel_allButGR','KONModel_allButGR',...
            'Pars_KON_KOFF_KR_zeroOFF');
        transformSSAsoln =[];
        switch finalDUSP1model
            case 2
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
                zeroPars = 23;
                valsFreePars = FinalModel_allButGR;
                load(savedParsFile,'ktptl_FinalModel_allButGR');
                ktptl = ktptl_FinalModel_allButGR;

            case 3 % No Saturation, All Pars Fit
                [fullSSAModel] = dusp1ModelLibrary_Final('altSSAModel_NoSaturation_100',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26];
                load(savedParsFile,'FinalModelNoSaturation');
                valsFreePars = FinalModelNoSaturation;
                zeroPars = [23];
                load(savedParsFile,'ktptl_FinalModelNoSaturation');
                ktptl = ktptl_FinalModelNoSaturation;
                % Account for change in Dex for the No Sat model.
                fullSSAModel.inputExpressions{2,2} = ...
                    ['1+TTP1*(',num2str(ITTPscale),')*(t^eta/(t^eta+tTTP^eta))*(t>0)'];

            case 4 % No Time Variation, All Pars Fit
                [fullSSAModel] = dusp1ModelLibrary_Final('altSSAModel_NoTimeVariation_100',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,24,25,26];
                load(savedParsFile,'FinalModelNoTimeVariation');
                valsFreePars = FinalModelNoTimeVariation;
                zeroPars = [23];
                load(savedParsFile,'ktptl_FinalModelNoTimeVariation');
                ktptl = ktptl_FinalModelNoTimeVariation;
            
            case 5
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24];
                zeroPars = [23,25,26];
                valsFreePars = KONModel_allButGR;
                load(savedParsFile,'ktptl_KONModel_allButGR');
                ktptl = ktptl_KONModel_allButGR;

            case 7
                indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
                zeroPars = 23;
                valsFreePars = FinalModel_allButGR_NoPrior;
                load(savedParsFile,'ktptl_FinalModel_allButGR_NoPrior');
                ktptl = ktptl_FinalModel_allButGR_NoPrior;

            case 8 % First Order Decay
                indsFreePars =  [1,2,3,4,14,19,24,25,26];
                zeroPars = [15,16,21,22,23];
                fullSSAModel.propensityFunctions(10) = {'degCyt0*rCyt'};
                load(savedParsFile,'Pars_first_order_decay');
                valsFreePars = Pars_first_order_decay;
                load(savedParsFile,'ktptl_Pars_first_order_decay');
                ktptl = ktptl_Pars_first_order_decay;

            case 10  %% Mechanistic model with TTP (with prior)
                fullSSAModel = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,19,24,25,26,27:36];
                load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All');
                valsFreePars = Pars_GR_DUSP1_TTP_Model_All;
                zeroPars = [20,21,22,23];
                transformSSAsoln = zeros(6,13);
                transformSSAsoln(1:6,1:6) = eye(6);
                transformSSAsoln(6,12) = 1;
                fullSSAModel.tSpan = [-500,fullSSAModel.dataSet.times];
                load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All');
                ktptl = ktptl_GR_DUSP1_TTP_Model_All;

            case 11  %% Mechanistic model with TTP
                fullSSAModel = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
                indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26,27:36];
                load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All_2');
                valsFreePars = Pars_GR_DUSP1_TTP_Model_All_2;
                zeroPars = [23];
                transformSSAsoln = zeros(6,13);
                transformSSAsoln(1:6,1:6) = eye(6);
                transformSSAsoln(6,12) = 1;
                fullSSAModel.tSpan = [-500,fullSSAModel.dataSet.times];
                load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All_2');
                ktptl = ktptl_GR_DUSP1_TTP_Model_All_2;

            % case 12  %% Mechanistic model with TTP and P38
            %     fullSSAModel = dusp1ModelLibrary_Final('GR_DUSP1_TTP_P38_Model_2',false,modelLibrary);
            %     indsFreePars = [1,2,3,4,14,15,19,20,21,22,24:44];
            %     load(savedParsFile,'Pars_GR_DUSP1_TTP_P38_Model_2');
            %     valsFreePars = Pars_GR_DUSP1_TTP_P38_Model_2;
            %     zeroPars = [23];
            %     transformSSAsoln = zeros(6,18);
            %     transformSSAsoln(1:6,1:6) = eye(6);
            %     transformSSAsoln(6,12) = 1;
            %     load(savedParsFile,'ktptl_GR_DUSP1_TTP_P38_Model_2');
            %     ktptl = ktptl_GR_DUSP1_TTP_P38_Model_2;
        end
        if recomputeSSA
            fullSSAModel.tSpan = unique([-500,fullSSAModel.dataSet.times]);
            fullSSAModel.dataSet = titrDat{iModel};
            fullSSAModel.parameters([1,2,3,4,19,24,25,26],2) = num2cell(Pars_KON_KOFF_KR_zeroOFF);
            fullSSAModel.parameters(13,:) = dexPar;
            fullSSAModel.parameters(5:12,2) = num2cell(GRpars);
            fullSSAModel.parameters(18,2) = num2cell(ktptl);
            fullSSAModel.parameters(indsFreePars,2) = num2cell(valsFreePars);
            fullSSAModel.parameters(zeroPars,2) = num2cell(0*zeroPars);

            % increase number of sims for plotting.
            fullSSAModel.ssaOptions.nSimsPerExpt = 10000/length(fullSSAModel.tSpan);

            % Solve and make plots.
            [ssaSoln{iModel},~,fullSSAModel] = fullSSAModel.solve;
            
            % Nuc plots
            [~,figHandlesSSA(iModel,1:2)] = makeCytDistPlots(ssaSoln{iModel},fullSSAModel,...
                600+10*iModel,5,1,[0:5:300],false,'pdf',...
                [2,3],[1],'replica',true,transformSSAsoln);
            [~,figHandlesSSA(iModel,6:7)] = makeCytDistPlots(ssaSoln{iModel},fullSSAModel,...
                600+10*iModel,5,1,[0:5:300],true,'pdf',...
                [2,3],[1],'replica',true,transformSSAsoln);
            figHandlesSSA{iModel,1}.Name = ['Nuclear RNA (Dex=',num2str(fullSSAModel.parameters{13,2}),' nM)'];
            figHandlesSSA{iModel,6}.Name = ['Nuclear RNA (Dex=',num2str(fullSSAModel.parameters{13,2}),' nM)'];
           
            % Cyt plots
            [~,figHandlesSSA(iModel,3:4)] = makeCytDistPlots(ssaSoln{iModel},fullSSAModel,...
                601+10*iModel,6,2,[0:5:300],false,'pdf',...
                [2,3],[1],'replica',true,transformSSAsoln);
            [~,figHandlesSSA(iModel,8:9)] = makeCytDistPlots(ssaSoln{iModel},fullSSAModel,...
                601+10*iModel,6,2,[0:5:300],true,'pdf',...
                [2,3],[1],'replica',true,transformSSAsoln);
            figHandlesSSA{iModel,2}.Name = ['Cytoplasmic RNA (Dex=',num2str(fullSSAModel.parameters{13,2}),' nM)'];
            figHandlesSSA{iModel,8}.Name = ['Cytoplasmic RNA (Dex=',num2str(fullSSAModel.parameters{13,2}),' nM)'];
            
            % Scatter plots
            [figHandlesSSA{iModel,5}] = makeNucCytScatterPlots(ssaSoln{iModel},fullSSAModel,...
                602+10*iModel,[5,6],[1,2],true,...
                [2,3],[1],[],transformSSAsoln);
            figHandlesSSA{iModel,5}.Name = ['Nuc vs. Cyto RNA (Dex=',num2str(fullSSAModel.parameters{13,2}),' nM)'];
        end

        if ~exist(['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model}],'dir')
            mkdir(['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model}])
        end

        save(['savedResults/',savedFullParSet{finalDUSP1model},'_SSAResults'],'ssaSoln');
    end
    for i = 1:4
        switch i
            case 4
                dex = '100';
            case 3
                dex = '10';
            case 2
                dex = '1';
            case 1
                dex = '0p3';
        end

        outDir = fullfile(['savedFigures/RawFigs/', savedFullParSet{finalDUSP1model}]);
        if ~exist(outDir, 'dir')
            mkdir(outDir);
        end

        fileTags = { ...
            'NucDist', ...
            'NucMnVar', ...
            'CytDist', ...
            'CytMnVar', ...
            'JointNucCyt',...
            'NucDistReps',...
            '','CytDistReps'};

        for j = [1:5,6,8]
            h = figHandlesSSA{i,j};

            if isempty(h)
                warning('figHandlesSSA{%d,%d} is empty. Skipping.', i, j);
                continue
            end

            if ~isgraphics(h)
                warning('figHandlesSSA{%d,%d} is not a valid graphics handle. Skipping.', i, j);
                continue
            end

            if isa(h, 'matlab.ui.Figure')
                hFig = h;
            else
                hFig = ancestor(h, 'figure');
            end

            if isempty(hFig) || ~isgraphics(hFig, 'figure')
                warning('Could not resolve a valid figure for figHandlesSSA{%d,%d}. Skipping.', i, j);
                continue
            end

            outFile = fullfile(outDir, ['Dusp1_SSA_', dex, '_', fileTags{j}, '.fig']);
            saveas(hFig, outFile, 'fig');
        end
    end
end
close all

%%    Make TS, Nuc and Cyt Titration Plots
if makeTitrPlots 
    DexConc = 10.^[-3,-2,-1,0,1,2,3,4];
    DecConcStr = {'0.001','0.01','0.1','1','10','100','1000','10000'};
            
    ModelTtr = fullSSAModel;

    % Update paramters to use current values.
    ModelTtr.parameters(5:12,2) = num2cell(GRpars);
    ModelTtr.parameters(indsFreePars,2) = num2cell(valsFreePars);
    ModelTtr.parameters(zeroPars,2) = num2cell(0*zeroPars);

    % Objective function for just the TS analyses -- see function description
    % below. Only using time point 0 and 75 for the titration study.
    allData = readtable(dataFileDusp1);
    allData = allData(allData.cyto_area_px>=12593&allData.cyto_area_px<=17685&(allData.time==0|allData.time==75),:);
    
    % Reset SSA codes to make sure current version is being used.
    ModelTtr.ssaOptions.computeFile = [];

    if recomputeSSA
        for i=1:length(DexConc)
            % if i == 1
            % end

            if finalDUSP1model<=8
                % 
                Mod.parameters{13,2} = DexConc(i);
                [soln,~,Mod] = Mod.solve;
                vGRNuc = zeros(1,length(soln.fsp));
                for iT = 1:length(soln.fsp)
                    P = sum(double(soln.fsp{iT}.p.data),1)';
                    vGRNuc(iT) = [0:length(P)-1]*P;
                end

                ITTPscale = (mean(vGRNuc)./min(vGRNuc)-1)/GRNucScale(4);

                % Adjust TTP effect
                ModelTtr.inputExpressions{2,2} = ...
                    ['1+TTP1*(',num2str(ITTPscale),')*(t^eta/(t^eta+tTTP^eta))*(t>0)'];

                % Reset SSA compute file due to change in propensity
                % function.
                ModelTtr.ssaOptions.computeFile = [];
            end

            ModelTtr.parameters(13,2) = {DexConc(i)};
            ModelTtr = ModelTtr.loadData(dataFileDusp1,...
                {'rna','num_nuc_noTS'; ...
                'rCyt','num_cyto_spots'},...
                {[],[],['TAB.dex_conc==',DecConcStr{i},'&TAB.cyto_area_px>=12593&TAB.cyto_area_px<=17685&isnan(TAB.time_tpl)&TAB.time==75']},{'replica'});
            ModelTtr.ssaOptions.nSimsPerExpt = 10000/length(ModelTtr.tSpan);

            ModelTtr.ssaOptions.computeFile = [];
            [ModelPredDexTtrSoln,~,ModelTtr] = ModelTtr.solve;

            % Transformation to results of SSA.  For example, could combine two species
            % into one.
            if ~isempty(transformSSAsoln)
                ModelPredDexTtrSoln.trajs = tensorprod(transformSSAsoln, ModelPredDexTtrSoln.trajs, 2, 1);
            end

            MeanModel(i,:) = mean(squeeze(ModelPredDexTtrSoln.trajs(5:6,2,:)),2);
            SigMod(i,:) = std(squeeze(ModelPredDexTtrSoln.trajs(5:6,2,:)),[],2);
            MedianModel(i,:) = median(squeeze(ModelPredDexTtrSoln.trajs(5:6,2,:)),2);
            
            % Compute 25 and 75 percentiles.
            sorted = [sort(squeeze(ModelPredDexTtrSoln.trajs(5,2,:)))';...
                      sort(squeeze(ModelPredDexTtrSoln.trajs(6,2,:)))'];
            ModQuant25(i,:) = sorted(:,floor(size(sorted,2)/4));
            ModQuant75(i,:) = sorted(:,ceil(3*size(sorted,2)/4));

            DataHist = squeeze(double(ModelTtr.dataSet.app.DataLoadingAndFittingTabOutputs.dataTensor));

            MeanData(i,:) = [[0:size(DataHist,1)-1]*sum(DataHist,2),...
                [0:size(DataHist,2)-1]*sum(DataHist,1)']/sum(DataHist,"all");
            Mean2Data(i,:) = [[0:size(DataHist,1)-1].^2*sum(DataHist,2),...
                [0:size(DataHist,2)-1].^2*sum(DataHist,1)']/sum(DataHist,"all");
            SigDat(i,:) =  sqrt(Mean2Data(i,:) - MeanData(i,:).^2);
            
            % Compute 25 and 75 percentiles.
            chist = cumsum(sum(DataHist,2)')/sum(DataHist,'all');
            j11 = find(chist<0.25,1,'last')-1;
            j12 = find(chist>0.75,1,'first')-1;
            j13 = find(chist>0.5,1,'first')-1;
            chist = cumsum(sum(DataHist,1))/sum(DataHist,'all');
            j21 = find(chist<0.25,1,'last')-1;
            j22 = find(chist>0.75,1,'first')-1;
            j23 = find(chist>0.5,1,'first')-1;
            DatQuant25(i,:) = [j11,j21];
            DatQuant75(i,:) = [j12,j22];
            MedianData(i,:) = [j13,j23];


            %% TS Titration
            % ModelTS = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
            ModelTS = ModelTtr;
            ModelTS.parameters(5:12,2) = num2cell(GRpars);
            ModelTS.parameters(indsFreePars,2) = num2cell(valsFreePars);
            ModelTS.parameters{18,2} = ktptl;
            ModelTS.parameters(zeroPars,2) = num2cell(0*zeroPars);

            % Set initial nuc and cyt to zero.
            ModelTS.initialCondition(5:6) = 0;

            % No transport of nascent RNA;
            ModelTS.parameters{4,2} = 0;

            % For TS predictions, the signal starts at t=0, not t=tau_elong.
            ModelTS.propensityFunctions{3} = '(kcn0 + (t>0)*kcn1*IDex/(MDex+IDex)) * cytGR';
            ModelTS.inputExpressions{1,2} = 'Dex0*exp(-gDex*t)';

            % Pull the previously identified delay and assume that this delay comes
            % exclusively from nascent mRNA elongation.
            tau_elong = ModelTS.parameters{19,2};

            ModelTS.parameters{17,2} = 200; % no TPL
            allDataRed = allData(isnan(allData.time_tpl),:);

            ModelTS.parameters{13,2} = DexConc(i);
            ModelTS.tSpan = unique([allDataRed.time])';

            ModelTS.fittingOptions.modelVarsToFit = 19;
            TEMPCheck = ModelTS;
            ModelTS.ssaOptions.computeFile = [];
            [~,modelResults,dataResults] = computeTSlikelihoodSSA(tau_elong,ModelTS,allDataRed,50,true);

            meanNascTitrMod(i) = modelResults.meanNascentTSMod(end);
            meanNascTitrModStd(i) = modelResults.meanNascentTSModStd(end);
            fracTSMod(i) = modelResults.fracTSMod(end);
            fracTSModStd(i) = 1./sqrt(dataResults.N(end)).*sqrt(modelResults.fracTSMod(end).*(1-modelResults.fracTSMod(end)));

            meanNascTitrDat(i) = dataResults.meanNascentTSDat(end);
            meanNascTitrDatStd(i) = dataResults.meanNascentTSDatstd(end);
            fracTSDat(i) = dataResults.fracTSDat(end);
            fracTSDatStd(i) = dataResults.fracTSDatstd(end);

            % Save Titration Models and SSA Solution (trajectories)
            saveNames = unique({
                'ModelTtr'
                'ModelPredDexTtrSoln'
                'MeanModel'
                'SigMod'
                'MeanData'
                'SigDat'
                'ModelTS'
                'allDataRed'
                'modelResults'
                'dataResults'
                'meanNascTitrMod'
                'meanNascTitrModStd'
                'meanNascTitrDat'
                'fracTSMod'
                'fracTSModStd'
                'fracTSDat'
                'ModQuant25'
                'ModQuant75'              
                'DatQuant25'
                'DatQuant75'              
                'MedianData'
                'MedianModel'
                'fracTSDatStd'
                });
            save('ModelTtr',saveNames{:})
        end
    else
        load('ModelTtr.mat','MeanModel','SigMod','MeanData','SigDat',...
            'meanNascTitrMod','meanNascTitrModStd','meanNascTitrDat',...
            'fracTSMod','fracTSModStd','fracTSDat','ModQuant25',...
            'ModQuant75','DatQuant25','DatQuant75','MedianData',...
                'MedianModel')
    end
    figHandles{3} = figure('Visible',figVis);
    x = [DexConc,DexConc(end:-1:1)];
    % y = [MeanModel(:,1)-SigMod(:,1);MeanModel(end:-1:1,1)+SigMod(end:-1:1,1)]';
    y = [ModQuant25(:,1)',ModQuant75(end:-1:1,1)'];
    fill(x,y,[0.9,1,0.9])
    hold on
    % plot(DexConc,MeanModel(:,1),'k','LineWidth',3); hold on;
    plot(DexConc,MedianModel(:,1),'k','LineWidth',3); hold on;

    % errorbar(DexConc,MeanData(:,1),SigDat(:,1),'LineWidth',3,'LineStyle','none'); hold on;
    errorbar(DexConc,MedianData(:,1),MedianData(:,1)-DatQuant25(:,1),-MedianData(:,1)+DatQuant75(:,1),'LineWidth',3,'LineStyle','none','Marker','o'); hold on;
    % plot(DexConc,MeanData(:,1),'s','MarkerSize',18,'MarkerFaceColor','b');

    set(gca,'xscale','log','FontSize',16,'xlim',[9e-4,1.1e4],'ylim',[0,100])
    set(gca,'xtick',10.^[-2,0,2,4])
    title('Prediction of DUSP1 Expression - Nucleus')
    xlabel('Dex Concentration at 75 min')
    ylabel('Mean Nuclear DUSP1 Count')

    figHandles{4} = figure('Visible',figVis);
    x = [DexConc,DexConc(end:-1:1)];
    % y = [MeanModel(:,2)-SigMod(:,2);MeanModel(end:-1:1,2)+SigMod(end:-1:1,2)]';
    y = [ModQuant25(:,2)',ModQuant75(end:-1:1,2)'];
    fill(x,y,[0.9,1,0.9])
    hold on
    % plot(DexConc,MeanModel(:,2),'k','LineWidth',3); hold on;
    plot(DexConc,MedianModel(:,2),'k','LineWidth',3); hold on;

    % errorbar(DexConc,MeanData(:,2),SigDat(:,2),'LineWidth',3,'LineStyle','none'); hold on;
    errorbar(DexConc,MedianData(:,2),MedianData(:,2)-DatQuant25(:,2),-MedianData(:,2)+DatQuant75(:,2),'LineWidth',3,'LineStyle','none','Marker','o'); hold on;
    % plot(DexConc,MeanData(:,2),'s','MarkerSize',18,'MarkerFaceColor','b');

    set(gca,'xscale','log','FontSize',16,'xlim',[9e-4,1.1e4],'ylim',[0,220])
    set(gca,'xtick',10.^[-2,0,2,4])
    title('Prediction of DUSP1 Expression - Cytoplasm')
    xlabel('Dex Concentration at 75 min')
    ylabel('Mean Cytoplasmic DUSP1 Count')

    saveas(figHandles{3},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_Dex_Titration_Nuc.fig'],'fig');
    saveas(figHandles{4},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_Dex_Titration_Cyt.fig'],'fig');

    figHandles{5} = figure('Visible',figVis);
    x = [DexConc,DexConc(end:-1:1)];
    y = [meanNascTitrMod-meanNascTitrModStd,meanNascTitrMod(end:-1:1)+meanNascTitrModStd(end:-1:1)];
    fill(x,y,[0.9,1,0.9])
    hold on
    plot(DexConc,meanNascTitrMod,'k','LineWidth',3); hold on;

    % errorbar(DexConc,meanNascTitrDat,meanNascTitrDatStd,'LineWidth',3,'LineStyle','none'); hold on;
    plot(DexConc,meanNascTitrDat,'s','MarkerSize',18,'MarkerFaceColor','b');

    set(gca,'xscale','log','FontSize',16,'xlim',[9e-4,1.1e4],'YLim',[0,14])
    set(gca,'xtick',10.^[-2,0,2,4])
    title('Prediction of DUSP1 TS Intensity')
    xlabel('Dex Concentration at 75 min')
    ylabel('Average Nascent DUSP1 per Cell')

    figHandles{6} = figure('Visible',figVis);
    x = [DexConc,DexConc(end:-1:1)];
    y = [fracTSMod-fracTSModStd,fracTSMod(end:-1:1)+fracTSModStd(end:-1:1)];
    fill(x,y,[0.9,1,0.9])
    hold on
    plot(DexConc,fracTSMod,'k','LineWidth',3); hold on;

    errorbar(DexConc,fracTSDat,fracTSDatStd,'LineWidth',3,'LineStyle','none','Marker','o'); hold on;
    % plot(DexConc,fracTSDat,'s','MarkerSize',18,'MarkerFaceColor','b');

    set(gca,'xscale','log','FontSize',16,'xlim',[9e-4,1.1e4],'YLim',[0,0.6])
    set(gca,'xtick',10.^[-2,0,2,4])
    title('Prediction of DUSP1 TS Fraction')
    xlabel('Dex Concentration at 75 min')
    ylabel('Fraction with Active TS')

    saveas(figHandles{5},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_Dex_Titration_TS_MeanActive.fig'],'fig');
    saveas(figHandles{6},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_Dex_Titration_TS_FracActive.fig'],'fig');
end
close all

%%    Make Nuc and Cyt Tryptolide Response Plots

if makeTPLPlots

    savedFullParSet = {'FinalModel_cytPars','FinalModel_allButGR','FinalModelNoSaturation',...
        'FinalModelNoTimeVariation','KONModel_allButGR','KONModel_allButGR_NoPrior','FinalModel_allButGR_NoPrior',...
        'Pars_first_order_decay','Pars_GR_DUSP1_TTP_P38_Model',...
        'Pars_GR_DUSP1_TTP_Model_All','Pars_GR_DUSP1_TTP_Model_All_2','Pars_GR_DUSP1_TTP_P38_Model_2'};

    % Update parameters
    load(savedParsFile,'GRpars','FinalModel_allButGR','KONModel_allButGR');
    transformSSAsoln =[];
    switch finalDUSP1model
        case 2
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
            zeroPars = 23;
            valsFreePars = FinalModel_allButGR;
            load(savedParsFile,'ktptl_FinalModel_allButGR');
            ktptl = ktptl_FinalModel_allButGR;

        case 5
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24];
            zeroPars = [23,25,26];
            valsFreePars = KONModel_allButGR;
            load(savedParsFile,'ktptl_KONModel_allButGR');
            ktptl = ktptl_KONModel_allButGR;

        case 7
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
            zeroPars = 23;
            valsFreePars = FinalModel_allButGR_NoPrior;
            load(savedParsFile,'ktptl_FinalModel_allButGR_NoPrior');
            ktptl = ktptl_FinalModel_allButGR_NoPrior;

        case 8 % First Order Decay
            indsFreePars =  [1,2,3,4,14,19,24,25,26];
            zeroPars = [15,16,21,22,23];
            fullSSAModel.propensityFunctions(10) = {'degCyt0*rCyt'};
            load(savedParsFile,'Pars_first_order_decay');
            valsFreePars = Pars_first_order_decay;
            load(savedParsFile,'ktptl_Pars_first_order_decay');
            ktptl = ktptl_Pars_first_order_decay;

        case 10  %% Mechanistic model with TTP (with prior)
            fullSSAModel = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,19,24,25,26,27:36];
            load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All');
            valsFreePars = Pars_GR_DUSP1_TTP_Model_All;
            zeroPars = [20,21,22,23];
            transformSSAsoln = zeros(6,13);
            transformSSAsoln(1:6,1:6) = eye(6);
            transformSSAsoln(6,12) = 1;
            fullSSAModel.tSpan = [-500,fullSSAModel.dataSet.times];
            load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All');
            ktptl = ktptl_GR_DUSP1_TTP_Model_All;

        case 11  %% Mechanistic model with TTP
            fullSSAModel = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26,27:36];
            load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All_2');
            valsFreePars = Pars_GR_DUSP1_TTP_Model_All_2;
            zeroPars = [23];
            transformSSAsoln = zeros(6,13);
            transformSSAsoln(1:6,1:6) = eye(6);
            transformSSAsoln(6,12) = 1;
            fullSSAModel.tSpan = [-500,fullSSAModel.dataSet.times];
            load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All_2');
            ktptl = ktptl_GR_DUSP1_TTP_Model_All_2;

        % case 12  %% Mechanistic model with TTP and P38
        %     % fullSSAModel = dusp1ModelLibrary_Final('GR_DUSP1_TTP_P38_Model_2',false,modelLibrary);
        %     indsFreePars = [1,2,3,4,14,15,19,20,21,22,24:44];
        %     load(savedParsFile,'Pars_GR_DUSP1_TTP_P38_Model_2');
        %     valsFreePars = Pars_GR_DUSP1_TTP_P38_Model_2;
        %     zeroPars = [23];
        %     transformSSAsoln = zeros(6,18);
        %     transformSSAsoln(1:6,1:6) = eye(6);
        %     transformSSAsoln(6,12) = 1;
        %     load(savedParsFile,'ktptl_GR_DUSP1_TTP_P38_Model_2');
        %     ktptl = ktptl_GR_DUSP1_TTP_P38_Model_2;
    end

    if recomputeSSA
        figHandlesSSA_TPL = cell(5,5);
        ssaSolnTpl = cell(1,5);
        fullModelNames = {'ModelTPl_0min','ModelTPl_20min','ModelTPl_75min','ModelTPl_150min','ModelTPl_180min'};
        for iModel = 1:5
            ModelTPl = dusp1ModelLibrary_Final(fullModelNames{iModel},false,modelLibrary);
            dataTPL = ModelTPl.dataSet;
            tTPL = ModelTPl.parameters(17,:);
            tArray = ModelTPl.tSpan;

            if finalDUSP1model==12
                ModelTPl = dusp1ModelLibrary_Final('GR_DUSP1_TTP_P38_Model_2',false,modelLibrary);
                ModelTPl.dataSet = dataTPL;
                ModelTPl.parameters(17,:) = tTPL;
                ModelTPl.tSpan = tArray;
            elseif finalDUSP1model==10||finalDUSP1model==11
                ModelTPl = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
                ModelTPl.dataSet = dataTPL;
                ModelTPl.parameters(17,:) = tTPL;
                ModelTPl.tSpan = tArray;
            end

            % Update parameters
            ModelTPl.parameters(5:12,2) = num2cell(GRpars);
            ModelTPl.parameters(indsFreePars,2) = num2cell(valsFreePars);
            ModelTPl.parameters{18,2} = ktptl;
            ModelTPl.parameters(zeroPars,2) = num2cell(0*zeroPars);

            ModelTPl.ssaOptions.nSimsPerExpt = 10000/length(ModelTPl.tSpan);

            % Solve and make plots.
            [ssaSolnTpl{iModel},~,ModelTPl] = ModelTPl.solve;
        
            % Nuc Plots
            [~,figHandlesSSA_TPL(iModel,1:2)] = makeCytDistPlots(ssaSolnTpl{iModel},...
                ModelTPl,600+10*iModel,5,1,[0:5:300],false,'pdf',...
                [2,3],[1],[],true,transformSSAsoln);
            [~,figHandlesSSA_TPL(iModel,6:7)] = makeCytDistPlots(ssaSolnTpl{iModel},...
                ModelTPl,600+10*iModel,5,1,[0:5:300],true,'pdf',...
                [2,3],[1],[],true,transformSSAsoln);
            figHandlesSSA_TPL{iModel,1}.Name = ['Nuclear RNA (Dex=',num2str(ModelTPl.parameters{13,2}),' nM)'];
            figHandlesSSA_TPL{iModel,6}.Name = ['Nuclear RNA (Dex=',num2str(ModelTPl.parameters{13,2}),' nM)'];

            % Cyt Plots
            [~,figHandlesSSA_TPL(iModel,3:4)] = makeCytDistPlots(ssaSolnTpl{iModel},...
                ModelTPl,601+10*iModel,6,2,[0:5:300],false,'pdf',...
                [2,3],[1],[],true,transformSSAsoln);
            [~,figHandlesSSA_TPL(iModel,8:9)] = makeCytDistPlots(ssaSolnTpl{iModel},...
                ModelTPl,601+10*iModel,6,2,[0:5:300],true,'pdf',...
                [2,3],[1],[],true,transformSSAsoln);
            figHandlesSSA_TPL{iModel,2}.Name = ['Cytoplasmic RNA (Dex=',num2str(ModelTPl.parameters{13,2}),' nM)'];
            figHandlesSSA_TPL{iModel,8}.Name = ['Cytoplasmic RNA (Dex=',num2str(ModelTPl.parameters{13,2}),' nM)'];

            % Joint Plots
            [figHandlesSSA_TPL{iModel,5}] = makeNucCytScatterPlots(ssaSolnTpl{iModel},...
                ModelTPl,602+10*iModel,[5,6],[1,2],true,...
                [2,3],[1],[],transformSSAsoln);

            figHandlesSSA_TPL{iModel,5}.Name = ['Nuc vs. Cyto RNA (Dex=',num2str(ModelTPl.parameters{13,2}),' nM)'];
            
        end

        for i = 1:5
            switch i
                case 1
                    dex = 'Tpl_0min';
                case 2
                    dex = 'Tpl_20min';
                case 3
                    dex = 'Tpl_75min';
                case 4
                    dex = 'Tpl_150min';
                case 5
                    dex = 'Tpl_180min';
            end
            for j = [1:5,6,8]
                switch j
                    case 1
                        saveas(figHandlesSSA_TPL{i,j},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_',dex,'_NucDist.fig'],'fig');
                    case 2
                        saveas(figHandlesSSA_TPL{i,j},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_',dex,'_NucMnVar.fig'],'fig');
                    case 3
                        saveas(figHandlesSSA_TPL{i,j},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_',dex,'_CytDist.fig'],'fig');
                    case 4
                        saveas(figHandlesSSA_TPL{i,j},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_',dex,'_CytMnVar.fig'],'fig');
                    case 5
                        saveas(figHandlesSSA_TPL{i,j},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_',dex,'_JointNucCyt.fig'],'fig');
                    case 6
                        saveas(figHandlesSSA_TPL{i,j},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_',dex,'_NucDistReps.fig'],'fig');
                    case 8
                        saveas(figHandlesSSA_TPL{i,j},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_SSA_',dex,'_CytDistReps.fig'],'fig');
                end
            end
        end
    end
end
close all

%%    Make Transcription Site Activity Plots (w/ and w/o TPL)
%    Create Copy of the Full model and update to best parameters.
if ~isempty(finalDUSP1model) && makeTSPlots
    ModelTS = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);

        savedFullParSet = {'FinalModel_cytPars','FinalModel_allButGR','FinalModelNoSaturation',...
        'FinalModelNoTimeVariation','KONModel_allButGR','KONModel_allButGR_NoPrior','FinalModel_allButGR_NoPrior',...
        'Pars_first_order_decay','Pars_GR_DUSP1_TTP_P38_Model',...
        'Pars_GR_DUSP1_TTP_Model_All','Pars_GR_DUSP1_TTP_Model_All_2','Pars_GR_DUSP1_TTP_P38_Model_2'};

    % Update parameters
    load(savedParsFile,'GRpars','FinalModel_allButGR','KONModel_allButGR');
    transformSSAsoln=[];
    switch finalDUSP1model
        case 2
            ModelTS = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
            zeroPars = 23;
            valsFreePars = FinalModel_allButGR;
            load(savedParsFile,'ktptl_FinalModel_allButGR');
            ktptl = ktptl_FinalModel_allButGR;
        case 5
            ModelTS = dusp1ModelLibrary_Final('fullSSAModel_100_2StateGen',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24];
            zeroPars = [23,25,26];
            valsFreePars = KONModel_allButGR;
            load(savedParsFile,'ktptl_KONModel_allButGR');
            ktptl = ktptl_KONModel_allButGR;
        case 7
            indsFreePars =  [1,2,3,4,14,15,16,19,20,21,22,24,25,26];
            zeroPars = 23;
            valsFreePars = FinalModel_allButGR_NoPrior;
            load(savedParsFile,'ktptl_FinalModel_allButGR_NoPrior');
            ktptl = ktptl_FinalModel_allButGR_NoPrior;
        case 8 % First Order Decay
            indsFreePars =  [1,2,3,4,14,19,24,25,26];
            zeroPars = [15,16,21,22,23];
            fullSSAModel.propensityFunctions(10) = {'degCyt0*rCyt'};
            load(savedParsFile,'Pars_first_order_decay');
            valsFreePars = Pars_first_order_decay;
            load(savedParsFile,'ktptl_Pars_first_order_decay');
            ktptl = ktptl_Pars_first_order_decay;
        case 10  %% Mechanistic model with TTP
            ModelTS = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,19,24,25,26,27:36];
            load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All');
            valsFreePars = Pars_GR_DUSP1_TTP_Model_All;
            zeroPars = [20,21,22,23];
            transformSSAsoln = zeros(6,13);
            transformSSAsoln(1:6,1:6) = eye(6);
            transformSSAsoln(6,12) = 1;
            load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All');
            ktptl = ktptl_GR_DUSP1_TTP_Model_All;
        case 11  %% Mechanistic model with TTP
            ModelTS = dusp1ModelLibrary_Final('GR_DUSP1_TTP_Model_2',false,modelLibrary);
            indsFreePars =  [1,2,3,4,14,15,19,20,21,22,24,25,26,27:36];
            load(savedParsFile,'Pars_GR_DUSP1_TTP_Model_All_2');
            valsFreePars = Pars_GR_DUSP1_TTP_Model_All_2;
            zeroPars = [23];
            transformSSAsoln = zeros(6,13);
            transformSSAsoln(1:6,1:6) = eye(6);
            transformSSAsoln(6,12) = 1;
            load(savedParsFile,'ktptl_GR_DUSP1_TTP_Model_All_2');
            ktptl = ktptl_GR_DUSP1_TTP_Model_All_2;
        % case 12  %% Mechanistic model with TTP and P38
        %     ModelTS = dusp1ModelLibrary_Final('GR_DUSP1_TTP_P38_Model_2',false,modelLibrary);
        %     indsFreePars = [1,2,3,4,14,15,19,20,21,22,24:44];
        %     load(savedParsFile,'Pars_GR_DUSP1_TTP_P38_Model_2');
        %     valsFreePars = Pars_GR_DUSP1_TTP_P38_Model_2;
        %     zeroPars = [23];
        %     transformSSAsoln = zeros(6,18);
        %     transformSSAsoln(1:6,1:6) = eye(6);
        %     transformSSAsoln(6,12) = 1;
        %     load(savedParsFile,'ktptl_GR_DUSP1_TTP_P38_Model_2');
        %     ktptl = ktptl_GR_DUSP1_TTP_P38_Model_2;
    end
    if recomputeSSA
        ModelTS.parameters(5:12,2) = num2cell(GRpars);
        ModelTS.parameters(indsFreePars,2) = num2cell(valsFreePars);
        ModelTS.parameters{18,2} = ktptl;
        ModelTS.parameters(zeroPars,2) = num2cell(0*zeroPars);

        % Set initial nuc and cyt to zero.
        ModelTS.initialCondition(5:6) = 0;

        % No transport of nascent RNA;
        ModelTS.parameters{4,2} = 0;

        % For TS predictions, the signal starts at t=0, not t=tau_elong.
        ModelTS.propensityFunctions{3} = '(kcn0 + (t>0)*kcn1*IDex/(MDex+IDex)) * cytGR';
        ModelTS.inputExpressions{1,2} = 'Dex0*exp(-gDex*t)';

        % Objective function for just the TS analyses -- see function description
        % below.
        allData = readtable(dataFileDusp1);
        allData = allData(allData.cyto_area_px>=12593&allData.cyto_area_px<=17685,:);

        % Pull the previously identified delay and assume that this delay comes
        % exclusively from nascent mRNA elongation.
        tau_elong = ModelTS.parameters{19,2};

        dexA = [100,10,1,0.3,0,100,100,100,100];
        tplTime = [200,200,200,200,0,20,75,150,180];
        for i=1:9
            ModelTS.parameters{17,2} = tplTime(i);
            if i<=4
                allDataRed = allData(isnan(allData.time_tpl),:);
            else
                allDataRed = allData(allData.time_tpl==tplTime(i)|(isnan(allData.time_tpl)&allData.time<=tplTime(i)),:);
            end

            ModelTS.parameters{13,2} = dexA(i);

            ModelTS.tSpan = unique([allDataRed.time])';

            TMPCheck2 = ModelTS;
            [TSLikelihood,modelResults,dataResults] = computeTSlikelihoodSSA(tau_elong,ModelTS,allDataRed,50,true);
            saveNamesTS = unique({
                'ModelTS'
                'TSLikelihood'
                'modelResults'
                'dataResults'
                });
            save('ModelTS',saveNamesTS{:})
            figHandlesDusp1TS{i} = makeTSPlotsSSA(modelResults,dataResults,ModelTS,4,'pdf');
        end

        for i=1:9
            switch i
                case 1
                    dex = '100';
                case 2
                    dex = '10';
                case 3
                    dex = '1';
                case 4
                    dex = '0p3';
                case 5
                    dex = 'Tpl_0min';
                case 6
                    dex = 'Tpl_20min';
                case 7
                    dex = 'Tpl_75min';
                case 8
                    dex = 'Tpl_150min';
                case 9
                    dex = 'Tpl_180min';
            end
            saveas(figHandlesDusp1TS{i}{1},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_TS_',dex,'_Dists.fig'],'fig');
            saveas(figHandlesDusp1TS{i}{2},['savedFigures/RawFigs/',savedFullParSet{finalDUSP1model},'/Dusp1_TS_',dex,'_MeansAndFracs.fig'],'fig');
        end
    else
        load('ModelTS.mat','ModelTS','TSLikelihood','modelResults','dataResults')
    end
    fprintf('Log-likelihood for Transcription Site model (SSA): %g\n', TSLikelihood)
end
close all
