%XKONModel_allButGR_NoPrior, Dex = 100 nM: J_NucCyt=-141.6215; J_TS=-86.527; J_Total=228.1484
% KONModel_allButGR_NoPrior, Tpl = 0min nM: J_NucCyt=-19.8671; J_TS=0; J_Total=19.8671
