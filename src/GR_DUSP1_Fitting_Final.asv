% FinalModel_allButGR_NoPrior, Tpl = 75min nM: J_NucCyt=-39.3347; J_TS=0; J_Total=39.3347
% FinalModel_allButGR_NoPrior, Tpl = 150min nM: J_NucCyt=-26.8528; J_TS=0; J_Total=26.8528
