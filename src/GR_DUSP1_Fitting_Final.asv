% Model 7 - All Three
% FinalModel_allButGR_NoPrior, Dex = 0p3 nM: J_NucCyt=-65.0743; J_TS=-20.5008; J_Total=85.5751
% FinalModel_allButGR_NoPrior, Dex = 1 nM: J_NucCyt=-63.4899; J_TS=-29.1993; J_Total=92.6892
% FinalModel_allButGR_NoPrior, Dex = 10 nM: J_NucCyt=-94.7506; J_TS=-46.4401; J_Total=141.1906
